{%- endcapture -%}

<div class="color-{{ section.settings.color_scheme }} gradient" id="sv-{{ uid }}">
  <div class="page-width">
    <div class="sv-inner">
      {%- for block in section.blocks -%}
        {%- assign tag = 'div' -%}
        {%- if block.settings.link != blank -%}{%- assign tag = 'a' -%}{%- endif -%}

        {%- capture icon_svg -%}
          {%- case block.settings.icon -%}
            {%- when 'repair'    -%}{{ svg_repair }}
            {%- when 'authentic' -%}{{ svg_authentic }}
            {%- when 'paylater'  -%}{{ svg_paylater }}
            {%- when 'knocking'  -%}{{ svg_knocking }}
            {%- when 'shipping'  -%}{{ svg_shipping }}
            {%- when 'star'      -%}{{ svg_star }}
            {%- when 'tag'       -%}{{ svg_tag }}
            {%- when 'return'    -%}{{ svg_return }}
          {%- endcase -%}
        {%- endcapture -%}

        <{{ tag }}
          class="sv-card"
          {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="sv-icon" aria-hidden="true">{{ icon_svg }}</span>
          <span class="sv-text">
            <span class="sv-label">{{ block.settings.label }}</span>
            {%- if block.settings.sublabel != blank -%}
              <span class="sv-sub">{{ block.settings.sublabel }}</span>
            {%- endif -%}
          </span>
        </{{ tag }}>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- style -%}
  #sv-{{ uid }} { padding-top: 0; padding-bottom: 0; }
{%- endstyle -%}

{% schema %}
{
  "name": "22 Yard Services",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "repair",    "label": "Wrench / Repair" },
            { "value": "authentic", "label": "Shield / Authentic" },
            { "value": "paylater",  "label": "Card / Pay Later" },
            { "value": "knocking",  "label": "Sun / Knocking" },
            { "value": "shipping",  "label": "Truck / Shipping" },
            { "value": "star",      "label": "Star" },
            { "value": "tag",       "label": "Tag / Price" },
            { "value": "return",    "label": "Return / Refresh" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sub-label",
          "default": "On orders over $99"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "22 Yard Services",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "icon": "repair",
            "label": "Bat Repairing Service",
            "sublabel": "Professional repair available"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "authentic",
            "label": "100% Authentic",
            "sublabel": "Genuine products guaranteed"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "paylater",
            "label": "Buy Now & Pay Later",
            "sublabel": "Flexible payment options"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "knocking",
            "label": "Free Bat Knocking",
            "sublabel": "Oiling and taping included"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "shipping",
            "label": "Free Shipping",
            "sublabel": "On orders over $99"
          }
        }
      ]
    }
  ]
}
{% endschema %}
