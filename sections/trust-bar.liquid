{%- comment -%}
  22 Yard — Services / Trust Bar
  ---------------------------------------------------------------
  A row of icon + text cards highlighting key store promises.
  Each card is a schema block so merchants can reorder, edit
  label/sub-label, pick an icon, and link optionally.
{%- endcomment -%}

{%- liquid
  assign uid = section.id
-%}

<style>
  /* ---- Section shell ---- */
  #sv-{{ uid }} {
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }

  /* ---- Desktop: single row ---- */
  #sv-{{ uid }} .sv-inner {
    display: flex;
    align-items: stretch;
  }

  /* ---- Card ---- */
  #sv-{{ uid }} .sv-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: .9rem;
    flex: 1 1 0;
    padding: 2.4rem 1.6rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: background .18s ease;
  }

  #sv-{{ uid }} .sv-card:hover {
    background: rgba(126, 27, 37, .04);
  }

  /* Vertical dividers between cards on desktop */
  #sv-{{ uid }} .sv-card + .sv-card::before {
    content: '';
    position: absolute;
    left: 0; top: 15%; bottom: 15%;
    width: 1px;
    background: #e5e7eb;
  }

  /* ---- Icon circle ---- */
  #sv-{{ uid }} .sv-icon {
    flex-shrink: 0;
    width: 52px; height: 52px;
    border-radius: 50%;
    background: #7e1b25;
    display: flex; align-items: center; justify-content: center;
    transition: background .18s ease, transform .18s ease;
  }
  #sv-{{ uid }} .sv-card:hover .sv-icon {
    background: #6a1520;
    transform: scale(1.08);
  }
  #sv-{{ uid }} .sv-icon svg {
    width: 24px; height: 24px;
    stroke: #fff;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ---- Text ---- */
  #sv-{{ uid }} .sv-text { min-width: 0; }
  #sv-{{ uid }} .sv-label {
    display: block;
    font-size: 1.3rem;
    font-weight: 700;
    color: #16161a;
    line-height: 1.3;
  }
  #sv-{{ uid }} .sv-sub {
    display: block;
    font-size: 1.15rem;
    color: #6b7280;
    line-height: 1.4;
    margin-top: .25rem;
  }

  @media screen and (min-width: 1200px){
        #sv-{{ uid }} .sv-card{
            flex-direction: row;
            text-align: left;
        }
    }

  /* ---- Tablet: 3-col wrap (600–989px) ---- */
  @media (max-width: 989px) and (min-width: 600px) {
    #sv-{{ uid }} .sv-inner {
      flex-wrap: wrap;
    }
    #sv-{{ uid }} .sv-card {
      flex: 1 1 calc(33.333% - 1px);
      border-bottom: 1px solid #e5e7eb;
      padding: 2rem 1.2rem;
    }
    #sv-{{ uid }} .sv-card + .sv-card::before { display: none; }
    /* Right border to simulate grid lines */
    #sv-{{ uid }} .sv-card:not(:nth-child(3n)) {
      border-right: 1px solid #e5e7eb;
    }
    /* Last row (4th + 5th card): no bottom border, each takes 50% */
    #sv-{{ uid }} .sv-card:nth-child(4),
    #sv-{{ uid }} .sv-card:nth-child(5) {
      flex: 1 1 calc(50% - 1px);
      border-bottom: none;
    }
    #sv-{{ uid }} .sv-card:nth-child(3) {
      border-right: none;
    }
  }

  /* ---- Mobile: stacked list (< 600px) ---- */
  @media (max-width: 599px) {
    #sv-{{ uid }} .sv-inner {
      flex-direction: column;
    }
    #sv-{{ uid }} .sv-card {
      flex-direction: row;
      text-align: left;
      justify-content: flex-start;
      align-items: center;
      gap: 1.4rem;
      padding: 1.5rem 2rem;
      border-bottom: 1px solid #e5e7eb;
    }
    #sv-{{ uid }} .sv-card:last-child {
      border-bottom: none;
    }
    #sv-{{ uid }} .sv-card + .sv-card::before { display: none; }
    #sv-{{ uid }} .sv-icon {
      width: 44px; height: 44px;
      flex-shrink: 0;
    }
    #sv-{{ uid }} .sv-icon svg { width: 20px; height: 20px; }
    #sv-{{ uid }} .sv-label { font-size: 1.35rem; }
    #sv-{{ uid }} .sv-sub { font-size: 1.2rem; }
  }
</style>

{%- comment -%} SVG icon library {%- endcomment -%}
