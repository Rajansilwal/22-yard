{%- comment -%}
  Promo Banner Section
  Settings: background image, overlay (color + opacity), heading, subheading,
  button, full-width toggle, and content alignment (left / center / right).
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign overlay_opacity = s.overlay_opacity | divided_by: 100.0
  assign is_full_width = s.full_width
-%}

{%- style -%}
  #Banner-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    min-height: {{ s.mobile_height }}px;
    overflow: hidden;
  }

  #Banner-{{ section.id }} .promo-banner__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #Banner-{{ section.id }} .promo-banner__overlay {
    position: absolute;
    inset: 0;
    background-color: {{ s.overlay_color }};
    opacity: {{ overlay_opacity }};
    pointer-events: none;
  }

  #Banner-{{ section.id }} .promo-banner__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    padding: 2rem 1.6rem;
  }

  /* Constrained (non-full-width): content aligned to page-width */
  #Banner-{{ section.id }} .promo-banner__inner-constrained {
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 1.6rem;
    display: flex;
  }

  #Banner-{{ section.id }} .promo-banner__content {
    max-width: min(100%, {{ s.content_width }}px);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  #Banner-{{ section.id }} .promo-banner__heading {
    margin: 0;
    color: {{ s.heading_color }};
    font-family: var(--font-heading-family);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.01em;
    /* Mobile-first: compact size */
    font-size: clamp(2rem, 5vw, {{ s.heading_size }}px);
  }

  #Banner-{{ section.id }} .promo-banner__subheading {
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    line-height: 1.5;
    max-width: 52rem;
  }

  #Banner-{{ section.id }} .promo-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    color: #16161a;
    border: 1.5px solid #ffffff;
    padding: 0.9rem 2rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    align-self: flex-start;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  #Banner-{{ section.id }} .promo-banner__button:hover {
    background: #16161a;
    color: #ffffff;
    border-color: #16161a;
  }

  /* Content alignment */
  #Banner-{{ section.id }}.promo-banner--left   .promo-banner__inner,
  #Banner-{{ section.id }}.promo-banner--left   .promo-banner__inner-constrained { justify-content: flex-start; }
  #Banner-{{ section.id }}.promo-banner--center .promo-banner__inner,
  #Banner-{{ section.id }}.promo-banner--center .promo-banner__inner-constrained { justify-content: center; }
  #Banner-{{ section.id }}.promo-banner--right  .promo-banner__inner,
  #Banner-{{ section.id }}.promo-banner--right  .promo-banner__inner-constrained { justify-content: flex-end; }

  #Banner-{{ section.id }}.promo-banner--left   .promo-banner__content { text-align: left;   align-items: flex-start; }
  #Banner-{{ section.id }}.promo-banner--center .promo-banner__content { text-align: center; align-items: center; }
  #Banner-{{ section.id }}.promo-banner--right  .promo-banner__content { text-align: right;  align-items: flex-end; }

  #Banner-{{ section.id }}.promo-banner--center .promo-banner__subheading {
    margin-left: auto;
    margin-right: auto;
  }

  /* Desktop overrides */
  @media screen and (min-width: 750px) {
    #Banner-{{ section.id }} {
      min-height: {{ s.desktop_height }}px;
    }
    #Banner-{{ section.id }} .promo-banner__inner {
      padding: 3rem 5rem;
    }
    #Banner-{{ section.id }} .promo-banner__inner-constrained {
      padding: 0 5rem;
    }
    #Banner-{{ section.id }} .promo-banner__content {
      gap: 1.4rem;
    }
    #Banner-{{ section.id }} .promo-banner__button {
      font-size: 1.4rem;
      padding: 1.1rem 2.4rem;
    }
  }
{%- endstyle -%}

<div id="Banner-{{ section.id }}" class="promo-banner promo-banner--{{ s.content_alignment }}{% unless is_full_width %} promo-banner--contained{% endunless %}">
  {%- if s.background_image != blank -%}
    {{
      s.background_image
      | image_url: width: 3000
      | image_tag:
        loading: 'lazy',
        class: 'promo-banner__media',
        sizes: '100vw',
        widths: '375, 750, 1100, 1500, 2000, 3000'
    }}
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'promo-banner__media promo-banner__placeholder' }}
  {%- endif -%}

  <div class="promo-banner__overlay"></div>

  <div class="promo-banner__inner">
    {%- if is_full_width -%}
      <div class="promo-banner__content">
        {%- if s.heading != blank -%}
          <h2 class="promo-banner__heading">{{ s.heading }}</h2>
        {%- endif -%}
        {%- if s.subheading != blank -%}
          <p class="promo-banner__subheading">{{ s.subheading }}</p>
        {%- endif -%}
        {%- if s.button_label != blank -%}
          <a href="{{ s.button_link }}" class="promo-banner__button">{{ s.button_label }}</a>
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="promo-banner__inner-constrained">
        <div class="promo-banner__content">
          {%- if s.heading != blank -%}
            <h2 class="promo-banner__heading">{{ s.heading }}</h2>
          {%- endif -%}
          {%- if s.subheading != blank -%}
            <p class="promo-banner__subheading">{{ s.subheading }}</p>
          {%- endif -%}
          {%- if s.button_label != blank -%}
            <a href="{{ s.button_link }}" class="promo-banner__button">{{ s.button_label }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "class": "section-promo-banner",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false,
      "info": "When disabled, content is constrained to the theme's page width."
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 200,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "default": 560
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Height (desktop)",
      "min": 200,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 480
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Height (mobile)",
      "min": 150,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 360
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Season Sale Up To 30% Off Kits & Bats"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (desktop)",
      "min": 24,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "info": "Optional text below the heading."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Sale"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}
