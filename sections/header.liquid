<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'header-layout.css' | asset_url }}" media="print" onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'component-cart-notification.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' or section.blocks.size > 0 -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- comment -%} No Swiper needed — none of the 3 layouts use a slider {%- endcomment -%}
{%- endif -%}

<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 1200px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }

  /* ===== 22 Yard header restyle ===== */
  .section-header {
    --yard-red: #e0242b;
    background: #ffffff;
  }

  .header-wrapper {
    background: #ffffff;
  }

  /* White top bar: logo left, centered search, icons right — 1200px+ only */
  .header.header--layout-22yard {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 2rem;
    grid-template-areas: 'logo search icons';
  }

  .header.header--layout-22yard .header__heading {
    grid-area: logo;
    margin: 0;
  }

  .header.header--layout-22yard .header__heading-link {
    padding: 0;
  }

  .header.header--layout-22yard .header__search-inline {
    grid-area: search;
    width: 100%;
  }

  .header.header--layout-22yard .header__icons {
    grid-area: icons;
    column-gap: 0.4rem;
  }

  .header.header--layout-22yard header-drawer {
    grid-area: logo;
    display: none;
  }

/* Below 1200px: toggle left | logo center | icons right ── */
  @media screen and (max-width: 1199px) {
    .header.header--layout-22yard {
      grid-template-columns: 2fr 1fr 2fr;
      grid-template-areas: 'drawer logo icons';
      column-gap: 1rem;
    }

    /* Show the hamburger drawer toggle on the left */
    .header.header--layout-22yard header-drawer {
      grid-area: drawer;
      display: flex;
      align-items: center;
      margin-left: -0.6rem;
    }

    /* Logo centered */
    .header.header--layout-22yard .header__heading {
      grid-area: logo;
      margin: 0;
      justify-self: center;
    }

    /* Icons on the right — tighter gap */
    .header.header--layout-22yard .header__icons {
      grid-area: icons;
      column-gap: 0.8rem;
    }

    /* Hide all text labels — icons only */
    .header.header--layout-22yard .header__icon-label {
      display: none !important;
    }

    /* Remove circle border on mobile icons to save space */
    .header.header--layout-22yard .header__icons .header__icon > .svg-wrapper,
    .header.header--layout-22yard .header__icons .header__icon account-icon .svg-wrapper {
      width: 3.6rem;
      height: 3.6rem;
      border: none;
    }

    /* Hide desktop-only icons on mobile */
    .header.header--layout-22yard .header__icon--wishlist,
    .header.header--layout-22yard .header__icon--account {
      display: none;
    }

    /* Hide the inline search bar below 1200px (search icon opens modal) */
    .header.header--layout-22yard .header__search-inline {
      display: none;
    }
  }

  /* Search: light-grey filled box, magnifier on the left, no submit button */
  .header-search-inline {
    width: 100%;
    max-width: var(--search-max-width, 480px);
    margin: 0;
  }

  .header-search-inline__field {
    position: relative;
    display: flex;
    align-items: center;
    border: 1px solid #e7e7e7;
    border-radius: 6px;
    background: #efefef;
    padding: 0 1rem;
    height: 4.4rem;
  }

  .header-search-inline__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9aa0a8;
    margin-right: 0.8rem;
  }

  .header-search-inline__icon svg {
    width: 1.7rem;
    height: 1.7rem;
  }

  .header-search-inline__input.field__input {
    flex: 1 1 auto;
    border: 0;
    background: transparent;
    box-shadow: none;
    height: 100%;
    padding: 0;
    font-size: 1.4rem;
    color: #16161a;
  }

  .header-search-inline__input.field__input:focus,
  .header-search-inline__input.field__input:focus-visible {
    box-shadow: none;
    outline: 0;
  }

  .header-search-inline__input::placeholder {
    color: #8b9097;
    opacity: 1;
  }

  /* Submit button hidden — the magnifier sits on the left */
  .header-search-inline .search__button.field__button {
    display: none;
  }

  .header-search-inline .reset__button.field__button {
    position: static;
    width: 2.4rem;
    height: 3.6rem;
    color: #9aa0a8;
  }

  /* ===== Icons: circular outline + visible text label ===== */
  .header.header--layout-22yard .header__icons {
    grid-area: icons;
    display: flex;
    align-items: center;
    column-gap: 1.6rem;
  }

  .header__icons .header__icon {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    width: auto;
    height: auto;
    color: #16161a;
    text-decoration: none;
  }

  .header__icons .header__icon > .svg-wrapper,
  .header__icons .header__icon account-icon .svg-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    flex: 0 0 auto;
    border-radius: 50%;
    color: #16161a;
  }

  .header__icons .header__icon > .svg-wrapper svg,
  .header__icons .header__icon account-icon .svg-wrapper svg {
    width: 100%;
    height: 100%;
  }

  .header__icon-label {
    font-size: 1.6rem;
    font-weight: 500;
    color: #16161a;
    white-space: nowrap;
    line-height: 1;
  }

  .header__icons .header__icon:hover .header__icon-label,
  .header__icons .header__icon:hover > .svg-wrapper {
    color: #8a2b2b;
    border-color: #8a2b2b;
  }

  /* The cart count is shown in the label text, so hide the floating bubble */
  .header.header--layout-22yard .cart-count-bubble {
    display: none;
  }

  /* ===== White navigation bar with thin top/bottom borders ===== */
  .header__nav-bar {
    background: #ffffff;
    width: 100%;
    border-top: 1px solid #e7e7e7;
    border-bottom: 1px solid #e7e7e7;
  }

  .header__nav-bar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .header__nav-bar .header__inline-menu {
    margin: 0;
  }

  .header__nav-bar .list-menu--inline {
    justify-content: center;
    gap: 0;
  }

  .header__nav-bar .header__menu-item {
    color: #222222;
    font-weight: 500;
    font-size: 1.8rem;
    letter-spacing: 0;
    text-transform: none;
    padding: 1.3rem 1.6rem;
    transition: color 0.15s ease;
  }

  .header__nav-bar .header__menu-item span {
    color: #222222;
  }

  .header__nav-bar .header__menu-item:hover,
  .header__nav-bar .header__menu-item:hover span {
    color: #8a2b2b;
  }

  .header__nav-bar .header__menu-item .icon-caret {
    color: currentColor;
  }

  .header__nav-bar .header__active-menu-item {
    text-decoration: none;
    color: #8a2b2b;
  }

  /* Hide the desktop nav bar below 1200px — links live in the drawer */
  @media screen and (max-width: 1199px) {
    .header__nav-bar {
      display: none;
    }
  }
</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 3rem;
  }

  .section-header {
    position: sticky;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- if section.settings.header_max_width != blank -%}
    .header.page-width {
      max-width: {{ section.settings.header_max_width }}px;
    }
  {%- endif -%}
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{%- liquid
  # 22 Yard design: always logo-left + centered inline search + red nav bar below.
  assign header_layout = '22yard'
  assign has_inline_search = true
-%}

{% liquid
  assign header_tag = 'div'

  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
%}

<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}
    data-sticky-type="{{ section.settings.sticky_header_type }}"
  {% endif %}
  class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}"
>
  {%- liquid
    assign social_links = false
    assign localization_forms = false

    if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
      assign social_links = true
    endif

    if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
      assign localization_forms = true
    endif
  -%}

  <header
    class="header header--layout-{{ header_layout }}{% if has_inline_search %} header--has-inline-search{% endif %} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if social_links %} header--has-social{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}{% if localization_forms %} header--has-localizations{% endif %}"
  >
    {%- liquid
      if section.settings.menu != blank
        render 'header-drawer'
      endif

      unless has_inline_search
        render 'header-search', input_id: 'Search-In-Modal-1'
      endunless
    -%}

    {%- comment -%} Logo — always wrapped in .header__heading so it's a grid child {%- endcomment -%}
    <{% if request.page_type == 'index' %}h1{% else %}div{% endif %} class="header__heading">
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo motion-reduce',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </{% if request.page_type == 'index' %}h1{% else %}div{% endif %}>

    {%- comment -%} Desktop navigation now lives in the red nav bar below the top bar {%- endcomment -%}

    {%- comment -%} Centered inline search bar {%- endcomment -%}
    {%- if has_inline_search -%}
      <div class="header__search-inline small-hide">
        {%- render 'header-search-inline', input_id: 'Search-Inline-Header' -%}
      </div>
    {%- endif -%}

    <div class="header__icons{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header__icons--localization header-localization{% endif %}">
      <div class="desktop-localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'HeaderCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {% endif %}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                {%- render 'language-localization', localPosition: 'HeaderLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
      {%- unless has_inline_search -%}
        {% render 'header-search', input_id: 'Search-In-Modal' %}
      {%- endunless -%}
      {%- if has_inline_search -%}
        {%- comment -%} Mobile: always show popup search icon {%- endcomment -%}
        <div class="large-up-hide">
          {% render 'header-search', input_id: 'Search-In-Modal-Mobile' %}
        </div>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="header__icon header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %}"
          rel="nofollow"
        >
          {%- if section.settings.enable_customer_avatar -%}
            <account-icon>
              {%- if customer and customer.has_avatar? -%}
                {{ customer | avatar }}
              {%- else -%}
                <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
              {%- endif -%}
            </account-icon>
          {%- else -%}
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
          {%- endif -%}
          <span class="header__icon-label">{{ 'customer.account_fallback' | t | default: 'Account' }}</span>
        </a>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <a
        href="{{ settings.wishlist_url | default: routes.search_url }}"
        class="header__icon header__icon--wishlist link focus-inset small-hide"
        aria-label="{{ 'general.wishlist' | t | default: 'Wishlist' }}"
      >
        <span class="svg-wrapper">
        <svg class="icon icon-wishlist" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
<rect x="0.5" y="0.5" width="39" height="39" rx="19.5" fill="#F9F9F9"/>
<rect x="0.5" y="0.5" width="39" height="39" rx="19.5" stroke="#B2B2B2"/>
<path d="M29.9998 16.862C30.0032 18.4007 29.4104 19.881 28.3458 20.992C25.9048 23.523 23.5367 26.162 21.0057 28.6C20.4247 29.15 19.5038 29.13 18.9488 28.555L11.6537 20.993C9.44875 18.707 9.44875 15.017 11.6537 12.732C12.1749 12.185 12.8017 11.7495 13.4961 11.452C14.1906 11.1544 14.9382 11.001 15.6937 11.001C16.4493 11.001 17.1969 11.1544 17.8914 11.452C18.5858 11.7495 19.2126 12.185 19.7338 12.732L19.9998 13.006L20.2648 12.732C20.7865 12.1857 21.4134 11.7507 22.1077 11.453C22.802 11.1554 23.5493 11.0013 24.3048 11C25.8248 11 27.2777 11.624 28.3447 12.732C29.4097 13.8428 30.0029 15.3231 29.9998 16.862Z" stroke="black" stroke-width="1.5" stroke-linejoin="round"/>
</svg>

        </span>
        <span class="header__icon-label">Wishlist(0)</span>
      </a>

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
        {% if cart == empty %}
          <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
        {% else %}
          <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {% endif %}
        <span class="header__icon-label">Cart ({{ cart.item_count }} item)</span>
        {%- if cart != empty -%}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
            <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
          </div>
        {%- endif -%}
      </a>
    </div>
  </header>

  {%- comment -%} Bright-red desktop navigation bar {%- endcomment -%}
  {%- if section.settings.menu != blank and section.settings.menu_type_desktop != 'drawer' -%}
    <div class="header__nav-bar small-hide">
      <div class="header__nav-bar-inner page-width">
        {%- if section.settings.menu_type_desktop == 'dropdown' -%}
          {%- render 'header-dropdown-menu' -%}
        {%- else -%}
          {%- render 'header-mega-menu', blocks: section.blocks -%}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</{{ header_tag }}>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification',
    color_scheme: section.settings.color_scheme,
    desktop_menu_type: section.settings.menu_type_desktop
  -%}
{%- endif -%}

{% javascript %}
  class StickyHeader extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.header = document.querySelector('.section-header');
      this.headerIsAlwaysSticky =
        this.getAttribute('data-sticky-type') === 'always' ||
        this.getAttribute('data-sticky-type') === 'reduce-logo-size';
      this.headerBounds = {};

      this.setHeaderHeight();

      window.matchMedia('(max-width: 1199px)').addEventListener('change', this.setHeaderHeight.bind(this));

      if (this.headerIsAlwaysSticky) {
        this.header.classList.add('shopify-section-header-sticky');
      }

      this.currentScrollTop = 0;
      this.preventReveal = false;
      this.predictiveSearch = this.querySelector('predictive-search');

      this.onScrollHandler = this.onScroll.bind(this);
      this.hideHeaderOnScrollUp = () => (this.preventReveal = true);

      this.addEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.addEventListener('scroll', this.onScrollHandler, false);

      this.createObserver();
    }

    setHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', `${this.header.offsetHeight}px`);
    }

    disconnectedCallback() {
      this.removeEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.removeEventListener('scroll', this.onScrollHandler);
    }

    createObserver() {
      let observer = new IntersectionObserver((entries, observer) => {
        this.headerBounds = entries[0].intersectionRect;
        observer.disconnect();
      });

      observer.observe(this.header);
    }

    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      if (this.predictiveSearch && this.predictiveSearch.isOpen) return;

      if (scrollTop > this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (this.preventHide) return;
        requestAnimationFrame(this.hide.bind(this));
      } else if (scrollTop < this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (!this.preventReveal) {
          requestAnimationFrame(this.reveal.bind(this));
        } else {
          window.clearTimeout(this.isScrolling);

          this.isScrolling = setTimeout(() => {
            this.preventReveal = false;
          }, 66);

          requestAnimationFrame(this.hide.bind(this));
        }
      } else if (scrollTop <= this.headerBounds.top) {
        this.header.classList.remove('scrolled-past-header');
        requestAnimationFrame(this.reset.bind(this));
      }

      this.currentScrollTop = scrollTop;
    }

    hide() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
      this.closeMenuDisclosure();
      this.closeSearchModal();
    }

    reveal() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-sticky', 'animate');
      this.header.classList.remove('shopify-section-header-hidden');
    }

    reset() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.remove('shopify-section-header-hidden', 'shopify-section-header-sticky', 'animate');
    }

    closeMenuDisclosure() {
      this.disclosures = this.disclosures || this.header.querySelectorAll('header-menu');
      this.disclosures.forEach((disclosure) => disclosure.close());
    }

    closeSearchModal() {
      this.searchModal = this.searchModal || this.header.querySelector('details-modal');
      this.searchModal.close(false);
    }
  }

  customElements.define('sticky-header', StickyHeader);
{% endjavascript %}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "select",
      "id": "menu_type_desktop",
      "options": [
        { "value": "dropdown", "label": "t:sections.header.settings.menu_type_desktop.options__1.label" },
        { "value": "mega",     "label": "t:sections.header.settings.menu_type_desktop.options__2.label" },
        { "value": "drawer",   "label": "t:sections.header.settings.menu_type_desktop.options__3.label" }
      ],
      "default": "dropdown",
      "label": "t:sections.header.settings.menu_type_desktop.label",
      "info": "Default menu style. Override per item using blocks below."
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "range",
      "id": "search_max_width",
      "min": 300,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Search bar max width",
      "default": 720,
      "info": "Applies to the inline search bar in 'Logo left + Search' and 'Logo top' layouts."
    },
    {
      "type": "header",
      "content": "Header max width"
    },
    {
      "type": "text",
      "id": "header_max_width",
      "label": "Max width (px, leave blank for theme default)",
      "placeholder": "e.g. 1400"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__1.content"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none",            "label": "t:sections.header.settings.sticky_header_type.options__1.label" },
        { "value": "on-scroll-up",    "label": "t:sections.header.settings.sticky_header_type.options__2.label" },
        { "value": "always",          "label": "t:sections.header.settings.sticky_header_type.options__3.label" },
        { "value": "reduce-logo-size","label": "t:sections.header.settings.sticky_header_type.options__4.label" }
      ],
      "default": "on-scroll-up",
      "label": "t:sections.header.settings.sticky_header_type.label"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "t:sections.header.settings.menu_color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__utilities.content"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_country_selector.label",
      "info": "t:sections.header.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_language_selector.label",
      "info": "t:sections.header.settings.enable_language_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_customer_avatar",
      "default": true,
      "label": "t:sections.header.settings.enable_customer_avatar.label",
      "info": "t:sections.header.settings.enable_customer_avatar.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.margin_bottom.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "Custom CSS class"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class(es)",
      "info": "Add one or more space-separated CSS classes to the section wrapper. Useful for custom styling."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "menu_item_override",
      "name": "Menu item override",
      "settings": [
        {
          "type": "paragraph",
          "content": "Match this block to a nav item by its handle. The handle is the title lowercased with spaces as hyphens, e.g. 'Shop All' → 'shop-all'."
        },
        {
          "type": "text",
          "id": "menu_item_handle",
          "label": "Menu item handle",
          "info": "e.g. 'cricket-bats', 'sale', 'clothing'"
        },
        {
          "type": "header",
          "content": "Submenu type"
        },
        {
          "type": "select",
          "id": "menu_type",
          "label": "Menu type",
          "options": [
            { "value": "default", "label": "Use section default" },
            { "value": "mega", "label": "Mega menu" },
            { "value": "dropdown", "label": "Dropdown" },
            { "value": "none", "label": "Plain link (no submenu)" }
          ],
          "default": "default"
        },
        {
          "type": "header",
          "content": "Mega menu layout"
        },
        {
          "type": "select",
          "id": "mega_layout",
          "label": "Layout",
          "options": [
            { "value": "columns-with-products", "label": "Columns + Featured Products" },
            { "value": "columns-with-promo", "label": "Columns + Flash Deals + Promo Banner" },
            { "value": "columns-with-image", "label": "Columns + Promo Image" }
          ],
          "default": "columns-with-image"
        },
        {
          "type": "range",
          "id": "mega_columns",
          "min": 2,
          "max": 5,
          "step": 1,
          "label": "Number of link columns",
          "default": 3
        },
        {
          "type": "checkbox",
          "id": "mega_show_description",
          "label": "Show descriptions under links",
          "default": false
        },
        {
          "type": "header",
          "content": "Right panel — Collection (Layouts 1 & 2)"
        },
        {
          "type": "collection",
          "id": "mega_collection_handle",
          "label": "Collection",
          "info": "Layout 1: shows up to 2 product cards + View All. Layout 2: shows flash deals product list."
        },
        {
          "type": "header",
          "content": "Right panel — Promo image (Layouts 2 & 3)"
        },
        {
          "type": "image_picker",
          "id": "mega_featured_image",
          "label": "Promo image"
        },
        {
          "type": "text",
          "id": "mega_featured_heading",
          "label": "Eyebrow / badge label",
          "info": "Small label above the main heading (e.g. 'CUSTOM TEAMWEAR', 'END OF SEASON')"
        },
        {
          "type": "text",
          "id": "promo_heading",
          "label": "Main heading",
          "info": "Large bold heading on the promo panel"
        },
        {
          "type": "text",
          "id": "promo_text",
          "label": "CTA button label",
          "default": "Shop Now →"
        },
        {
          "type": "url",
          "id": "promo_link",
          "label": "CTA button link"
        }
      ]
    }
  ]
}
{% endschema %}
