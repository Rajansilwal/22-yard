{% comment %}
  Testimonials Slider — generic Dawn-compatible section
  Updated to match new design:
   - Small uppercase label above heading
   - Left-aligned heading + rating summary
   - Optional "View All" button on top-right
   - Verified tick beside name
   - Bottom-right quote mark on card
   - Location/role under name
{% endcomment %}

{%- liquid
  assign s = section.settings
  assign sid = section.id
-%}

{% style %}
  .testimonials-{{ sid }} {
    padding: {{ s.padding_top }}px 0 {{ s.padding_bottom }}px;
    background-color: {{ s.background_color }};
    color: {{ s.text_color }};
  }
  .testimonials-{{ sid }} .testimonials__container {
    max-width: {{ s.container_width }}px;
    margin: 0 auto;
    padding: 0 16px;
  }

  /* ---------- Top header row ---------- */
  .testimonials-{{ sid }} .testimonials__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .testimonials-{{ sid }} .testimonials__top-left {
    flex: 1 1 auto;
    min-width: 240px;
  }
  .testimonials-{{ sid }} .testimonials__label {
    color: {{ s.label_color }};
    font-size: {{ s.label_size }}px;
    letter-spacing: 0.12em;
    font-weight: 600;
    text-transform: uppercase;
    margin: 0 0 10px;
  }
  .testimonials-{{ sid }} .testimonials__heading {
    text-align: left;
    font-size: {{ s.heading_size }}px;
    margin: 0 0 12px;
    color: {{ s.heading_color }};
    line-height: 1.15;
  }
  .testimonials-{{ sid }} .testimonials__highlight { color: {{ s.highlight_color }}; }

  /* Rating summary line under heading */
  .testimonials-{{ sid }} .testimonials__rating-summary {
    font-size: {{ s.rating_summary_size }}px;
    color: {{ s.text_color }};
    line-height: 1.5;
    margin: 0;
    opacity: 0.85;
  }
  .testimonials-{{ sid }} .testimonials__rating-summary strong {
    font-weight: 700;
    opacity: 1;
  }

  /* Optional subheading (legacy support) */
  .testimonials-{{ sid }} .testimonials__subheading {
    text-align: left;
    font-size: {{ s.text_size }}px;
    max-width: 760px;
    margin: 8px 0 0;
    line-height: 1.6;
    opacity: 0.85;
  }

  /* View All button */
  .testimonials-{{ sid }} .testimonials__view-all {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 26px;
    border: 1px solid {{ s.viewall_border_color }};
    background: {{ s.viewall_background }};
    color: {{ s.viewall_text_color }};
    font-size: {{ s.viewall_text_size }}px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: {{ s.viewall_radius }}px;
    transition: background .2s, color .2s, transform .2s;
  }
  .testimonials-{{ sid }} .testimonials__view-all:hover {
    background: {{ s.viewall_hover_background }};
    color: {{ s.viewall_hover_text_color }};
    transform: translateY(-1px);
  }

  /* ---------- Card ---------- */
  .testimonials-{{ sid }} .testimonials__card {
    position: relative;
    background-color: {{ s.card_background }};
    border-radius: {{ s.card_radius }}px;
    padding: 28px 26px;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid {{ s.card_border_color }};
    box-sizing: border-box;
    overflow: hidden;
  }

  /* Quote mark - bottom-right, large, faded */
  .testimonials-{{ sid }} .testimonials__quotemark {
    position: absolute;
    bottom: 14px;
    right: 18px;
    font-family: Georgia, serif;
    font-size: 6rem;
    line-height: 0.6;
    color: {{ s.quotemark_color }};
    opacity: {{ s.quotemark_opacity | divided_by: 100.0 }};
    transform: rotate(180deg);
    pointer-events: none;
    user-select: none;
  }

  .testimonials-{{ sid }} .testimonials__stars {
    color: {{ s.star_color }};
    letter-spacing: 2px;
    margin-bottom: 14px;
    font-size: 1.5rem;
    line-height: 1;
  }

  .testimonials-{{ sid }} .testimonials__quote {
    font-size: {{ s.quote_size }}px;
    line-height: 1.6;
    margin: 0 0 22px;
    flex: 1 1 auto;
    position: relative;
    z-index: 1;
  }

  /* Author row */
  .testimonials-{{ sid }} .testimonials__author {
    display: flex;
    align-items: center;
    gap: 14px;
    position: relative;
    z-index: 1;
  }
  .testimonials-{{ sid }} .testimonials__avatar {
    width: 42px;
    height: 42px;
    flex: none;
    border-radius: 50%;
    overflow: hidden;
    background-color: {{ s.card_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .testimonials-{{ sid }} .testimonials__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .testimonials-{{ sid }} .testimonials__initial {
    font-weight: 800;
    font-size: 1.05rem;
    color: {{ s.highlight_color }};
  }
  .testimonials-{{ sid }} .testimonials__name-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .testimonials-{{ sid }} .testimonials__name-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .testimonials-{{ sid }} .testimonials__name {
    font-weight: 700;
    font-size: {{ s.name_size }}px;
    color: {{ s.heading_color }};
    line-height: 1.2;
  }
  .testimonials-{{ sid }} .testimonials__verified {
    display: inline-flex;
    width: 16px;
    height: 16px;
    color: {{ s.verified_color }};
  }
  .testimonials-{{ sid }} .testimonials__verified svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .testimonials-{{ sid }} .testimonials__role {
    font-size: {{ s.role_size }}px;
    opacity: 0.65;
    line-height: 1.2;
  }

  /* Single-column emphasis */
  .testimonials-{{ sid }}.is-single .testimonials__card {
    text-align: left;
    padding: 36px 32px;
  }
  .testimonials-{{ sid }}.is-single .testimonials__quote {
    font-size: {{ s.quote_size | plus: 2 }}px;
    max-width: 720px;
  }

  /* ---------- Swiper ---------- */
  .testimonials-{{ sid }} .testimonials__swiper { position: relative; padding: 0 52px 4px; }
  .testimonials-{{ sid }} .testimonials__swiper .swiper { overflow: hidden; }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-slide { height: auto; }

  /* Pre-init layout to prevent FOUC */
  .testimonials-{{ sid }} .swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    gap: 20px;
  }
  .testimonials-{{ sid }} .swiper:not(.swiper-initialized) .swiper-slide {
    flex: 0 0 calc((100% - 20px * ({{ s.per_mobile }} - 1)) / {{ s.per_mobile }});
  }
  @media screen and (min-width: 768px) {
    .testimonials-{{ sid }} .swiper:not(.swiper-initialized) .swiper-slide {
      flex-basis: calc((100% - 18px * ({{ s.per_tablet }} - 1)) / {{ s.per_tablet }});
    }
  }
  @media screen and (min-width: 1024px) {
    .testimonials-{{ sid }} .swiper:not(.swiper-initialized) .swiper-slide {
      flex-basis: calc((100% - 20px * ({{ s.per_desktop }} - 1)) / {{ s.per_desktop }});
    }
  }
  {%- if s.layout == 'single' -%}
  .testimonials-{{ sid }} .swiper:not(.swiper-initialized) .swiper-slide {
    flex-basis: 100% !important;
  }
  {%- endif -%}

  /* Arrows */
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-next,
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-prev {
    color: {{ s.arrow_icon_color }};
    background: {{ s.arrow_background }};
    width: 44px; height: 44px; border-radius: 50%;
    border: 1px solid {{ s.arrow_border_color }};
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    transition: transform .18s ease, opacity .18s ease, background .2s;
  }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-next:hover,
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-prev:hover {
    transform: scale(1.05);
    background: {{ s.arrow_hover_background }};
    color: {{ s.arrow_hover_icon_color }};
  }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-next:after,
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-prev:after { display: none; }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-next svg,
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-prev svg {
    display: block; width: 14px; height: 14px; color: currentColor;
  }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-disabled { opacity: 0.35; }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-prev { left: 0; }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-button-next { right: 0; }

  /* Arrow visibility per device */
  {% unless s.show_arrows_desktop %}
    @media screen and (min-width: 769px) {
      .testimonials-{{ sid }} .swiper-button-next, .testimonials-{{ sid }} .swiper-button-prev { display: none; }
    }
  {% endunless %}
  {% unless s.show_arrows_mobile %}
    @media screen and (max-width: 768px) {
      .testimonials-{{ sid }} .swiper-button-next, .testimonials-{{ sid }} .swiper-button-prev { display: none !important; }
    }
  {% endunless %}

  /* Pagination */
  .testimonials-{{ sid }} .testimonials__swiper .swiper-pagination { position: static; margin-top: 22px; }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-pagination-bullet {
    background: {{ s.text_color }}; opacity: 0.35;
    width: 9px; height: 9px; transition: opacity .2s, transform .2s;
  }
  .testimonials-{{ sid }} .testimonials__swiper .swiper-pagination-bullet-active {
    background: {{ s.highlight_color }}; opacity: 1; transform: scale(1.25);
  }
  {% unless s.show_pagination_desktop %}
    @media screen and (min-width: 769px) {
      .testimonials-{{ sid }} .swiper-pagination { display: none; }
    }
  {% endunless %}
  {% unless s.show_pagination_mobile %}
    @media screen and (max-width: 768px) {
      .testimonials-{{ sid }} .swiper-pagination { display: none !important; }
    }
  {% endunless %}

  /* ---------- Responsive ---------- */
  @media screen and (max-width: 768px) {
    .testimonials-{{ sid }} .testimonials__heading { font-size: {{ s.mobile_heading_size }}px; }
    .testimonials-{{ sid }} .testimonials__top {
      flex-direction: column;
      align-items: flex-start;
    }
    .testimonials-{{ sid }} .testimonials__view-all {
      align-self: flex-start;
    }
    .testimonials-{{ sid }} .testimonials__swiper { padding: 0 0 4px; }
  }
{% endstyle %}

{%- comment %} Load Swiper {% endcomment -%}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<section id="testimonials-{{ sid }}" class="testimonials-{{ sid }} testimonials-section{% if s.layout == 'single' %} is-single{% endif %} {{ s.custom_class }}">
  <div class="testimonials__container">

    {%- if s.label != blank or s.heading != blank or s.rating_summary_text != blank or s.show_view_all -%}
      <div class="testimonials__top">
        <div class="testimonials__top-left">

          {%- if s.label != blank -%}
            <div class="testimonials__label">{{ s.label }}</div>
          {%- endif -%}

          {%- if s.heading != blank -%}
            <h2 class="testimonials__heading">
              {{ s.heading }}
              {%- if s.highlight_text != blank -%}
                <span class="testimonials__highlight">{{ s.highlight_text }}</span>
              {%- endif -%}
            </h2>
          {%- endif -%}

          {%- if s.rating_summary_text != blank -%}
            <div class="testimonials__rating-summary">{{ s.rating_summary_text }}</div>
          {%- endif -%}

          {%- if s.subheading != blank -%}
            <div class="testimonials__subheading">{{ s.subheading }}</div>
          {%- endif -%}

        </div>

        {%- if s.show_view_all -%}
          <a href="{{ s.view_all_url | default: '#' }}" class="testimonials__view-all">
            {{ s.view_all_text | default: 'View All' }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="testimonials__swiper" id="testimonials-swiper-{{ sid }}">
        <div class="swiper">
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              {%- assign bs = block.settings -%}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <div class="testimonials__card">

                  {%- if bs.show_stars -%}
                    <div class="testimonials__stars" aria-label="{{ bs.rating }} out of 5">
                      {%- for i in (1..5) -%}{%- if i <= bs.rating -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}
                    </div>
                  {%- endif -%}

                  {%- if bs.quote != blank -%}
                    <div class="testimonials__quote">{{ bs.quote }}</div>
                  {%- endif -%}

                  <div class="testimonials__author">
                    <div class="testimonials__avatar">
                      {%- if bs.image != blank -%}
                        <img src="{{ bs.image | image_url: width: 120 }}" alt="{{ bs.name | escape }}" loading="lazy" width="42" height="42">
                      {%- elsif bs.image_url != blank -%}
                        <img src="{{ bs.image_url }}" alt="{{ bs.name | escape }}" loading="lazy">
                      {%- else -%}
                        <span class="testimonials__initial">{{ bs.name | strip | slice: 0 | upcase }}</span>
                      {%- endif -%}
                    </div>
                    <div class="testimonials__name-wrap">
                      {%- if bs.name != blank -%}
                        <div class="testimonials__name-row">
                          <div class="testimonials__name">{{ bs.name }}</div>
                          {%- if bs.verified -%}
                            <span class="testimonials__verified" aria-label="Verified">
                              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M12 2l2.39 2.45 3.32-.61.61 3.32L20.77 9.6 19.06 12l1.71 2.4-2.45 2.45-3.32.61-.61 3.32L12 22l-2.39-2.45-3.32.61-.61-3.32L3.23 14.4 4.94 12 3.23 9.6l2.45-2.45 3.32-.61.61-3.32L12 2z"/>
                                <path d="M10.5 14.6L7.9 12l-1 1 3.6 3.6 7-7-1-1z" fill="#ffffff"/>
                              </svg>
                            </span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      {%- if bs.role != blank -%}
                        <div class="testimonials__role">{{ bs.role }}</div>
                      {%- endif -%}
                    </div>
                  </div>

                  <div class="testimonials__quotemark" aria-hidden="true">&ldquo;</div>

                </div>
              </div>
            {%- endfor -%}
          </div>
          {%- if s.show_pagination_desktop or s.show_pagination_mobile -%}
            <div class="swiper-pagination"></div>
          {%- endif -%}
        </div>
        {%- if s.show_arrows_desktop or s.show_arrows_mobile -%}
          <div class="swiper-button-prev" aria-label="Previous">
            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="swiper-button-next" aria-label="Next">
            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        {%- endif -%}
      </div>

      <script>
        (function () {
          function initTestimonials() {
            if (typeof Swiper === 'undefined') { return setTimeout(initTestimonials, 60); }
            var el = document.querySelector('#testimonials-swiper-{{ sid }} .swiper');
            if (!el || el.dataset.inited) return;
            el.dataset.inited = '1';

            {%- if s.layout == 'single' -%}
              var perMobile = 1, perTablet = 1, perDesktop = 1;
            {%- else -%}
              var perMobile = {{ s.per_mobile }}, perTablet = {{ s.per_tablet }}, perDesktop = {{ s.per_desktop }};
            {%- endif -%}

            new Swiper(el, {
              slidesPerView: perMobile,
              slidesPerGroup: {% if s.dots_per_page %}perMobile{% else %}1{% endif %},
              spaceBetween: 18,
              loop: {% if s.loop and s.dots_per_page == false %}true{% else %}false{% endif %},
              autoHeight: {% if s.layout == 'single' %}true{% else %}false{% endif %},
              autoplay: {% if s.autoplay %}{ delay: {{ s.autoplay_speed | times: 1000 }}, disableOnInteraction: false }{% else %}false{% endif %},
              pagination: { el: '#testimonials-swiper-{{ sid }} .swiper-pagination', clickable: true },
              navigation: {
                nextEl: '#testimonials-swiper-{{ sid }} .swiper-button-next',
                prevEl: '#testimonials-swiper-{{ sid }} .swiper-button-prev'
              },
              breakpoints: {
                768:  { slidesPerView: perTablet,  slidesPerGroup: {% if s.dots_per_page %}perTablet{% else %}1{% endif %}, spaceBetween: 18 },
                1024: { slidesPerView: perDesktop, slidesPerGroup: {% if s.dots_per_page %}perDesktop{% else %}1{% endif %}, spaceBetween: 20 }
              }
            });
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initTestimonials);
          } else { initTestimonials(); }
          if (window.Shopify && Shopify.designMode) {
            document.addEventListener('shopify:section:load', initTestimonials);
          }
        })();
      </script>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "testimonials-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout style",
      "options": [
        { "value": "single", "label": "Single column (one per view)" },
        { "value": "multi", "label": "Multi column" }
      ],
      "default": "multi"
    },
    { "type": "range", "id": "per_desktop", "label": "Per view — desktop", "min": 1, "max": 4, "step": 1, "default": 3, "info": "Used in Multi column layout." },
    { "type": "range", "id": "per_tablet", "label": "Per view — tablet", "min": 1, "max": 3, "step": 1, "default": 2, "info": "Used in Multi column layout." },
    { "type": "range", "id": "per_mobile", "label": "Per view — mobile", "min": 1, "max": 3, "step": 1, "default": 1, "info": "Used in Multi column layout." },

    { "type": "header", "content": "Slider controls" },
    { "type": "checkbox", "id": "show_arrows_desktop", "label": "Show arrows on desktop", "default": true },
    { "type": "checkbox", "id": "show_arrows_mobile", "label": "Show arrows on mobile", "default": false },
    { "type": "checkbox", "id": "show_pagination_desktop", "label": "Show pagination dots on desktop", "default": false },
    { "type": "checkbox", "id": "show_pagination_mobile", "label": "Show pagination dots on mobile", "default": true },
    { "type": "checkbox", "id": "dots_per_page", "label": "One dot per page (group slides)", "info": "On: dots = number of pages. Looping is disabled when this is on.", "default": true },
    { "type": "checkbox", "id": "loop", "label": "Loop slides", "default": false },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": true },
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay delay", "min": 2, "max": 10, "step": 1, "unit": "s", "default": 5 },

    { "type": "header", "content": "Top label & heading" },
    { "type": "text", "id": "label", "label": "Small label above heading", "default": "TESTIMONIALS", "info": "Shown in uppercase, small caps style." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Says" },
    { "type": "text", "id": "highlight_text", "label": "Highlighted heading text" },
    { "type": "richtext", "id": "rating_summary_text", "label": "Rating summary line", "default": "<p><strong>4.9</strong> out of 5 Based on 2,400+ reviews</p>", "info": "Wrap part in <strong> to emphasise the score." },
    { "type": "richtext", "id": "subheading", "label": "Optional subheading (below rating)" },

    { "type": "header", "content": "View All button" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View All' button", "default": true },
    { "type": "text", "id": "view_all_text", "label": "Button text", "default": "VIEW ALL" },
    { "type": "url", "id": "view_all_url", "label": "Button link" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Body text color", "default": "#1a1a1a" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#0e0e0e" },
    { "type": "color", "id": "label_color", "label": "Small label color", "default": "#b3261e" },
    { "type": "color", "id": "highlight_color", "label": "Highlight color", "default": "#b3261e" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#f5a623" },
    { "type": "color", "id": "verified_color", "label": "Verified tick color", "default": "#1ea7fd" },
    { "type": "color", "id": "quotemark_color", "label": "Quote mark color", "default": "#c4c4c4" },
    { "type": "range", "id": "quotemark_opacity", "label": "Quote mark opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 35 },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border_color", "label": "Card border color", "default": "#e3e3e3" },

    { "type": "header", "content": "View All button colors" },
    { "type": "color", "id": "viewall_background", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "viewall_text_color", "label": "Text", "default": "#0e0e0e" },
    { "type": "color", "id": "viewall_border_color", "label": "Border", "default": "#0e0e0e" },
    { "type": "color", "id": "viewall_hover_background", "label": "Hover background", "default": "#0e0e0e" },
    { "type": "color", "id": "viewall_hover_text_color", "label": "Hover text", "default": "#ffffff" },

    { "type": "header", "content": "Arrow colors" },
    { "type": "color", "id": "arrow_background", "label": "Arrow background", "default": "#ffffff" },
    { "type": "color", "id": "arrow_icon_color", "label": "Arrow icon color", "default": "#0e0e0e" },
    { "type": "color", "id": "arrow_border_color", "label": "Arrow border color", "default": "#d9d9d9" },
