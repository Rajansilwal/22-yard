{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign use_swiper_desktop = false
  assign use_swiper_mobile = false
  if section.settings.layout_mode == 'slider'
    if section.settings.enable_swiper_desktop
      assign use_swiper_desktop = true
    endif
    if section.settings.enable_swiper_mobile
      assign use_swiper_mobile = true
    endif
  endif
-%}

{%- if use_swiper_desktop or use_swiper_mobile -%}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ---- Pre-init slide sizing to prevent FOUC ---- */
  {%- if section.settings.layout_mode == 'slider' -%}
    .cl-swiper-section[data-section-id="{{ section.id }}"] .swiper {
      overflow: hidden;
    }
    .cl-swiper-section[data-section-id="{{ section.id }}"] .swiper-wrapper {
      display: flex;
      flex-wrap: nowrap;
    }
    .cl-swiper-section[data-section-id="{{ section.id }}"] .swiper-slide {
      flex-shrink: 0;
      box-sizing: border-box;
      width: calc((100% - ({{ section.settings.columns_mobile | minus: 1 }} * 16px)) / {{ section.settings.columns_mobile }});
    }
    @media screen and (min-width: 750px) {
      .cl-swiper-section[data-section-id="{{ section.id }}"] .swiper-slide {
        width: calc((100% - ({{ section.settings.columns_desktop | minus: 1 }} * 20px)) / {{ section.settings.columns_desktop }});
      }
    }
    /* Smooth reveal after Swiper takes over */
    .cl-swiper-section[data-section-id="{{ section.id }}"]:not([data-swiper-ready]) {
      opacity: 1;
    }
  {%- endif -%}
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.layout_mode == 'grid' and section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient {{ section.settings.custom_class }}">
  <div class="collection-list-wrapper page-width isolate{% if show_mobile_slider %} page-width-desktop{% endif %}{% if section.settings.title == blank %} no-heading{% endif %}{% if section.settings.show_view_all == false %} no-mobile-link{% endif %} section-{{ section.id }}-padding">

    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link cl-header-row{% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% else %} title-wrapper--self-padded-mobile{% endif %} title-wrapper--no-top-margin">
        <div class="cl-header-text">
          {%- if section.settings.eyebrow != blank -%}
            <p class="cl-eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          <h2
            id="SectionHeading-{{ section.id }}"
            class="collection-list-title cl-heading inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          >
            {{ section.settings.title }}
          </h2>
        </div>
        <a href="{{ routes.collections_url }}" class="cl-outline-btn">ALL CATEGORIES</a>
        {%- if section.settings.show_view_all and show_mobile_slider -%}
          <a
            href="{{ routes.collections_url }}"
            id="ViewAll-{{ section.id }}"
            class="link underlined-link large-up-hide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            aria-labelledby="ViewAll-{{ section.id }} SectionHeading-{{ section.id }}"
          >
            {{- 'sections.collection_list.view_all' | t -}}
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}

    {%- if section.settings.layout_mode == 'slider' -%}
      {%- comment -%} ===== SWIPER SLIDER LAYOUT ===== {%- endcomment -%}
      <div
        class="cl-swiper-section{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        data-section-id="{{ section.id }}"
        data-swiper-desktop="{{ use_swiper_desktop }}"
        data-swiper-mobile="{{ use_swiper_mobile }}"
        data-columns-desktop="{{ section.settings.columns_desktop }}"
        data-columns-mobile="{{ section.settings.columns_mobile }}"
        data-arrows-desktop="{{ section.settings.show_arrows_desktop }}"
        data-arrows-mobile="{{ section.settings.show_arrows_mobile }}"
        data-pagination-desktop="{{ section.settings.show_pagination_desktop }}"
        data-pagination-mobile="{{ section.settings.show_pagination_mobile }}"
        data-arrow-position="{{ section.settings.arrow_position }}"
      >
        <div class="cl-swiper-inner">
          <button type="button" class="cl-swiper-btn cl-swiper-btn-prev-{{ section.id }}" aria-label="{{ 'general.slider.previous_slide' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <div class="swiper cl-swiper-{{ section.id }}" style="overflow: hidden;">
            <div class="swiper-wrapper" style="display: flex; flex-wrap: nowrap;">
              {%- liquid
                assign columns = section.blocks.size
                if columns > 3
                  assign columns = 3
                endif
              -%}
              {%- for block in section.blocks -%}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                  {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                  {% render 'card-collection',
                    card_collection: block.settings.collection,
                    media_aspect_ratio: section.settings.image_ratio,
                    columns: columns,
                    placeholder_image: placeholder_image
                  %}
                </div>
              {%- endfor -%}
            </div>
          </div>
          <button type="button" class="cl-swiper-btn cl-swiper-btn-next-{{ section.id }}" aria-label="{{ 'general.slider.next_slide' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
        {%- if section.settings.arrow_position == 'bottom_center' -%}
          <div class="cl-swiper-arrows--bottom-center">
            <button type="button" class="cl-swiper-btn cl-swiper-btn-bc-prev-{{ section.id }}" aria-label="{{ 'general.slider.previous_slide' | t }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button type="button" class="cl-swiper-btn cl-swiper-btn-bc-next-{{ section.id }}" aria-label="{{ 'general.slider.next_slide' | t }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        {%- endif -%}
        <div class="cl-swiper-pagination-{{ section.id }} cl-swiper-pagination"></div>
      </div>

      <script>
        (function () {
          function initClSwiper() {
            if (typeof Swiper === 'undefined') {
              setTimeout(initClSwiper, 100);
              return;
            }
            var el = document.querySelector('.cl-swiper-section[data-section-id="{{ section.id }}"]');
            if (!el) return;

            var isMobile = window.innerWidth < 750;
            var enableDesktop = el.dataset.swiperDesktop === 'true';
            var enableMobile = el.dataset.swiperMobile === 'true';
            var colsDesktop = parseInt(el.dataset.columnsDesktop) || 3;
            var colsMobile = parseInt(el.dataset.columnsMobile) || 1;
            var arrowsDesktop = el.dataset.arrowsDesktop === 'true';
            var arrowsMobile = el.dataset.arrowsMobile === 'true';
            var paginationDesktop = el.dataset.paginationDesktop === 'true';
            var paginationMobile = el.dataset.paginationMobile === 'true';
            var arrowPosition = el.dataset.arrowPosition || 'left_right';

            var enabled = isMobile ? enableMobile : enableDesktop;
            if (!enabled) {
              el.classList.add('cl-swiper--grid');
              el.style.setProperty('--cl-cols-desktop', colsDesktop);
              el.style.setProperty('--cl-cols-mobile', colsMobile);
              el.setAttribute('data-swiper-ready', 'true');
              return;
            }

            var showArrows = isMobile ? arrowsMobile : arrowsDesktop;
            var showPagination = isMobile ? paginationMobile : paginationDesktop;

            var prevBtn, nextBtn;
            var bcPrevBtn = el.querySelector('.cl-swiper-btn-bc-prev-{{ section.id }}');
            var bcNextBtn = el.querySelector('.cl-swiper-btn-bc-next-{{ section.id }}');
            var bcContainer = el.querySelector('.cl-swiper-arrows--bottom-center');

            if (arrowPosition === 'bottom_center' && bcPrevBtn && bcNextBtn) {
              prevBtn = bcPrevBtn;
              nextBtn = bcNextBtn;
              /* Hide the side arrows */
              var sidePrev = el.querySelector('.cl-swiper-btn-prev-{{ section.id }}');
              var sideNext = el.querySelector('.cl-swiper-btn-next-{{ section.id }}');
              if (sidePrev) sidePrev.style.display = 'none';
              if (sideNext) sideNext.style.display = 'none';
              if (!showArrows && bcContainer) bcContainer.style.display = 'none';
            } else {
              prevBtn = el.querySelector('.cl-swiper-btn-prev-{{ section.id }}');
              nextBtn = el.querySelector('.cl-swiper-btn-next-{{ section.id }}');
              /* Hide bottom-center arrows if present */
              if (bcContainer) bcContainer.style.display = 'none';
              if (!showArrows) {
                if (prevBtn) prevBtn.style.display = 'none';
                if (nextBtn) nextBtn.style.display = 'none';
              }
            }
            var paginationEl = el.querySelector('.cl-swiper-pagination-{{ section.id }}');
            if (!showPagination && paginationEl) {
              paginationEl.style.display = 'none';
            }

            new Swiper('.cl-swiper-{{ section.id }}', {
              slidesPerView: colsMobile,
              spaceBetween: 16,
              navigation: showArrows ? {
                nextEl: nextBtn,
                prevEl: prevBtn,
              } : false,
              pagination: showPagination ? {
                el: '.cl-swiper-pagination-{{ section.id }}',
                clickable: true,
              } : false,
              on: {
                init: function (swiper) {
                  if (!showArrows) {
                    var prevEl = el.querySelector('.cl-swiper-btn-prev-{{ section.id }}');
                    var nextEl = el.querySelector('.cl-swiper-btn-next-{{ section.id }}');
                    if (prevEl) prevEl.style.display = 'none';
                    if (nextEl) nextEl.style.display = 'none';
                  }
                  if (!showPagination) {
                    var pagEl = el.querySelector('.cl-swiper-pagination-{{ section.id }}');
                    if (pagEl) pagEl.style.display = 'none';
                  }
                  /* Mark ready — Swiper has taken over layout */
                  el.setAttribute('data-swiper-ready', 'true');
                },
              },
              breakpoints: {
                750: {
                  slidesPerView: colsDesktop,
                  spaceBetween: 20,
                },
              },
            });
          }
          /* Run as early as possible — don't wait for DOMContentLoaded if Swiper is already loaded */
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initClSwiper);
          } else {
            initClSwiper();
          }
        })();
      </script>

    {%- else -%}
      {%- comment -%} ===== DEFAULT GRID LAYOUT ===== {%- endcomment -%}
      <slider-component class="slider-mobile-gutter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <ul
          class="collection-list contains-card contains-card--collection{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if section.settings.swipe_on_mobile %} slider slider--tablet grid--peek{% endif %} collection-list--{{ section.blocks.size }}-items"
          id="Slider-{{ section.id }}"
          role="list"
        >
          {%- liquid
            assign columns = section.blocks.size
            if columns > 3
              assign columns = 3
            endif
          -%}
          {%- for block in section.blocks -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="collection-list__item grid__item{% if show_mobile_slider %} slider__slide{% endif %}{% if block.settings.collection.featured_image == nil %} collection-list__item--no-media{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
              {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
              {% render 'card-collection',
                card_collection: block.settings.collection,
                media_aspect_ratio: section.settings.image_ratio,
                columns: columns,
                placeholder_image: placeholder_image
              %}
            </li>
          {%- endfor -%}
        </ul>
        {%- if show_mobile_slider -%}
          <div class="slider-buttons">
            <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
              <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
            </button>
            <div class="slider-counter caption">
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ section.blocks.size }}</span>
            </div>
            <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
              <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
            </button>
          </div>
        {%- endif -%}
      </slider-component>
    {%- endif -%}

    {%- if section.settings.show_view_all -%}
      <div
        class="center collection-list-view-all{% if show_mobile_slider %} small-hide medium-hide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
      >
        <a
          href="{{ routes.collections_url }}"
          class="btn btn--{{ section.settings.button_style }}"
          id="ViewAllButton-{{ section.id }}"
          aria-labelledby="ViewAllButton-{{ section.id }} SectionHeading-{{ section.id }}"
        >
          {{- 'sections.collection_list.view_all' | t -}}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  /* ===== 22 Yard Category Slider — header + cards ===== */
  .section-collection-list .cl-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .section-collection-list .cl-eyebrow {
    margin: 0 0 0.4rem;
    color: #8a2b2b;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 1.6rem;
    line-height: 1;
  }
  .section-collection-list .cl-heading {
    margin: 0;
    color: #16161a;
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    font-weight: 700;
    line-height: 1.05;
  }
  .section-collection-list .cl-outline-btn {
    display: inline-block;
    background: #ffffff;
    border: 1.5px solid #16161a;
    color: #16161a;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.08em;
    font-size: 1.6rem;
    line-height: 1;
    padding: 1.4rem 2.4rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .section-collection-list .cl-outline-btn:hover {
    background: #16161a;
    color: #ffffff;
  }
  @media screen and (max-width: 749px) {
    .section-collection-list .cl-header-row {
      align-items: flex-start;
    }
  }

  /* Category cards: rounded image, dark bottom gradient, white-ish label box */
  .section-collection-list .card--collection,
  .section-collection-list .card-collection-wrapper .card {
    border-radius: 8px;
    overflow: hidden;
  }
  .section-collection-list .collection-card-wrapper .card__inner {
    border-radius: 8px;
    overflow: hidden;
  }
  .section-collection-list .collection-card-wrapper .card__media .media,
  .section-collection-list .collection-card-wrapper .card__media img {
    border-radius: 8px;
  }
  /* Dark gradient fading up from bottom */
  .section-collection-list .collection-card-wrapper .card__inner::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.35) 28%, rgba(0,0,0,0) 55%);
    pointer-events: none;
    z-index: 1;
  }
  /* Bottom-left white-ish rounded label box */
  .section-collection-list .collection-card-wrapper .card__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 0.9rem;
    pointer-events: none;
  }
  .section-collection-list .collection-card-wrapper .card__information {
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-radius: 6px;
    padding: 0.55rem 0.85rem;
    pointer-events: auto;
    max-width: calc(100% - 0.4rem);
  }
  .section-collection-list .collection-card-wrapper .card__heading {
    margin: 0;
    line-height: 1.15;
  }
  .section-collection-list .collection-card-wrapper .card__heading a {
    color: #000;
    font-size: 1.4rem;
    text-decoration: none;
  }
  .section-collection-list .collection-card-wrapper .card__heading .icon-wrap {
    display: none;
  }
  .section-collection-list .collection-card-wrapper .card-collection-count {
    display: block;
    margin: 0.15rem 0 0;
    color: #484848;
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.1;
  }

  /* Swiper grid fallback when slider is disabled for current breakpoint */
  .cl-swiper--grid .swiper-wrapper {
    display: grid;
    grid-template-columns: repeat(var(--cl-cols-mobile, 1), 1fr);
    gap: 16px;
    flex-wrap: unset;
    transform: none !important;
  }
  @media screen and (min-width: 750px) {
    .cl-swiper--grid .swiper-wrapper {
      grid-template-columns: repeat(var(--cl-cols-desktop, 3), 1fr);
      gap: 20px;
    }
  }
  .cl-swiper--grid .swiper-slide {
    width: auto !important;
    margin: 0 !important;
  }
  .cl-swiper--grid .cl-swiper-btn,
  .cl-swiper--grid .cl-swiper-pagination {
    display: none !important;
  }

  /* Slider layout */
  .cl-swiper-section {
    position: relative;
  }
  .cl-swiper-inner {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .cl-swiper-inner .swiper {
    flex: 1;
    min-width: 0;
  }
  .cl-swiper-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid currentColor;
    background: transparent;
    cursor: pointer;
    color: inherit;
    transition: background 0.2s, color 0.2s;
  }
  .cl-swiper-btn:hover {
    background: rgba(0,0,0,0.08);
  }
  .cl-swiper-btn.swiper-button-disabled {
    opacity: 0.35;
    cursor: default;
  }
  .cl-swiper-pagination {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 16px;
  }
  .cl-swiper-pagination .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.3;
    cursor: pointer;
  }
  .cl-swiper-pagination .swiper-pagination-bullet-active {
    opacity: 1;
  }

  /* Bottom-center arrow position */
  .cl-swiper-arrows--bottom-center {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.2rem;
    margin-top: 16px;
  }
  .cl-swiper-arrows--bottom-center .cl-swiper-btn {
    flex-shrink: 0;
  }
  .cl-swiper--grid .cl-swiper-arrows--bottom-center {
    display: none !important;
  }
</style>

{% schema %}
{
  "name": "22 Yard Category Slider",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "EXPLORE"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.collection-list.settings.title.default",
      "label": "t:sections.collection-list.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout mode",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider (Swiper)" }
      ],
      "default": "grid",
      "info": "Choose between a static grid or a Swiper carousel."
    },
    {
      "type": "checkbox",
      "id": "enable_swiper_desktop",
      "label": "Enable slider on desktop",
      "default": true,
      "info": "Only applies when Layout mode is Slider."
    },
    {
      "type": "checkbox",
      "id": "enable_swiper_mobile",
      "label": "Enable slider on mobile",
      "default": true,
      "info": "Only applies when Layout mode is Slider."
    },
    {
      "type": "checkbox",
      "id": "show_arrows_desktop",
      "label": "Show arrows on desktop",
      "default": true,
      "info": "Only applies when Layout mode is Slider."
    },
    {
      "type": "checkbox",
      "id": "show_arrows_mobile",
      "label": "Show arrows on mobile",
      "default": false,
