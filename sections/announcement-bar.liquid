{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign social_icons = false
  endif
  if section.settings.enable_country_selector or section.settings.enable_language_selector
    assign language_country_selector = true
  endif
  if section.blocks.size > 0
    assign announcement_bar = true
  endif
-%}

{% if social_icons %}
  {{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- style -%}
  /* ===== 22 Yard maroon ticker bar ===== */
  .yard-utility-{{ section.id }}.utility-bar {
    background: #8a2b2b;
    color: #ffffff;
    border: 0;
  }
  .yard-utility-{{ section.id }} .utility-bar__grid { padding-top: 0; padding-bottom: 0; }
  .yard-utility-{{ section.id }} .announcement-bar__message {
    color: #ffffff;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.04em;
    font-size: 1.2rem;
    margin: 0;
  }
  .yard-utility-{{ section.id }} .yard-ticker {
    overflow: hidden;
    width: 100%;
    padding: 0.9rem 0;
  }
  .yard-utility-{{ section.id }} .yard-ticker__track {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    will-change: transform;
    animation: yard-ticker-{{ section.id }} 36s linear infinite;
  }
  .yard-utility-{{ section.id }} .yard-ticker:hover .yard-ticker__track { animation-play-state: paused; }
  .yard-utility-{{ section.id }} .yard-ticker__item {
    color: #ffffff;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.04em;
    font-size: 1.2rem;
    text-decoration: none;
  }
  .yard-utility-{{ section.id }} .yard-ticker__sep {
    display: inline-block;
    margin: 0 2.6rem;
    color: #ffffff;
    opacity: 0.85;
  }
  @keyframes yard-ticker-{{ section.id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .yard-utility-{{ section.id }} .yard-ticker__track { animation: none; }
  }

  /* ===== Social icons — color & size ===== */
  .yard-utility-{{ section.id }} .list-social__link { color: {{ section.settings.social_icon_color }}; }
  .yard-utility-{{ section.id }} .list-social__link:hover { color: {{ section.settings.social_icon_hover_color }}; }
  .yard-utility-{{ section.id }} .list-social__item .icon {
    width: 24px;
    height: 24px;
    scale: 1;
  }

  /* ===== Announcement fills the row beside the icons (not centered) ===== */
  @media screen and (min-width: 990px) {
    /* Icons take their own width; announcement takes the rest of the row */
    .yard-utility-{{ section.id }} .utility-bar__grid--3-col {
      grid-template-columns: auto 1fr auto;
      column-gap: 2rem;
    }
    /* Announcement / ticker starts right after the icons, left-aligned, full width */
    .yard-utility-{{ section.id }} .announcement-bar { justify-content: flex-start; }
    .yard-utility-{{ section.id }} .announcement-bar.announcement-bar--one-announcement,
    .yard-utility-{{ section.id }} .announcement-bar--one-announcement .announcement-bar__link {
      width: 100%;
      margin: 0;
    }
  }

  /* ===== Social icons — position (desktop) ===== */
  {%- if section.settings.social_position == 'right' -%}
  @media screen and (min-width: 990px) {
    .yard-utility-{{ section.id }} .utility-bar__grid--3-col { grid-template-areas: 'language-currency announcements social-icons'; }
    .yard-utility-{{ section.id }} .utility-bar__grid--2-col { grid-template-areas: 'language-currency social-icons'; }
    .yard-utility-{{ section.id }} .utility-bar__grid .list-social {
      justify-content: flex-end;
      margin-left: 0;
      margin-right: -1.2rem;
    }
  }
  {%- endif -%}
{%- endstyle -%}

<div
  class="utility-bar yard-utility-{{ section.id }} gradient{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header-localization{% endif %} {{ section.settings.custom_class }}"
>
  <div class="page-width utility-bar__grid{% if announcement_bar and language_country_selector or section.settings.show_social and social_icons %} utility-bar__grid--3-col{% elsif language_country_selector or section.settings.show_social and social_icons %} utility-bar__grid--2-col{% endif %}">
    {%- if section.settings.show_social and social_icons -%}
      {%- render 'social-icons' -%}
    {%- endif -%}
    {%- if section.blocks.size == 1 -%}
      <div
        class="announcement-bar{% if section.settings.show_social %} announcement-bar--one-announcement{% endif %}"
        role="region"
        aria-label="{{ 'sections.header.announcement' | t }}"
        {{ section.blocks.first.shopify_attributes }}
      >
        {%- if section.blocks.first.settings.text != blank -%}
          {%- if section.blocks.first.settings.link != blank -%}
            <a
              href="{{ section.blocks.first.settings.link }}"
              class="announcement-bar__link link link--text focus-inset animate-arrow"
            >
          {%- endif -%}
          <p class="announcement-bar__message h5">
            <span>{{ section.blocks.first.settings.text | escape }}</span>
            {%- if section.blocks.first.settings.link != blank -%}
              {{- 'icon-arrow.svg' | inline_asset_content -}}
            {%- endif -%}
          </p>
          {%- if section.blocks.first.settings.link != blank -%}
            </a>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- elsif section.blocks.size > 1 -%}
      <div
        class="yard-ticker"
        role="region"
        aria-label="{{ 'sections.announcements.announcement_bar' | t }}"
      >
        <div class="yard-ticker__track">
          {%- comment -%} Rendered twice for a seamless marquee loop {%- endcomment -%}
          {%- for pass in (1..2) -%}
            {%- for block in section.blocks -%}
              {%- if block.settings.text != blank -%}
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="yard-ticker__item" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</a>
                {%- else -%}
                  <span class="yard-ticker__item" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</span>
                {%- endif -%}
                <span class="yard-ticker__sep" aria-hidden="true">&bull;</span>
              {%- endif -%}
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
    <div class="localization-wrapper">
      {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
        <localization-form class="small-hide medium-hide">
          {%- form 'localization', id: 'AnnouncementCountryForm', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="AnnouncementCountryLabel">{{ 'localization.country_label' | t }}</h2>
              {%- render 'country-localization', localPosition: 'AnnouncementCountry' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {% endif %}

      {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
        <localization-form class="small-hide medium-hide">
          {%- form 'localization', id: 'AnnouncementLanguageForm', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="AnnouncementLanguageLabel">{{ 'localization.language_label' | t }}</h2>
              {%- render 'language-localization', localPosition: 'AnnouncementLanguage' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.announcement-bar.settings.auto_rotate.label",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "t:sections.announcement-bar.settings.change_slides_speed.label",
      "default": 5
    },    
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },  
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "header",
      "content": "t:sections.announcement-bar.settings.heading_utilities.content"
    },
    {
      "type": "paragraph",
         "content": "t:sections.announcement-bar.settings.paragraph.content"
    },             
    {
      "type": "checkbox",
      "id": "show_social",
      "default": false,
      "label": "t:sections.announcement-bar.settings.show_social.label",
      "info": "t:sections.announcement-bar.settings.show_social.info"
    },
    {
      "type": "select",
      "id": "social_position",
      "label": "Social icons position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "info": "Shown on desktop. Uses the social links from Theme settings > Social media."
    },
    {
      "type": "color",
      "id": "social_icon_color",
      "label": "Social icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "social_icon_hover_color",
      "label": "Social icon hover color",
      "default": "#f1c40f"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "t:sections.announcement-bar.settings.enable_country_selector.label",
      "info": "t:sections.announcement-bar.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "t:sections.announcement-bar.settings.enable_language_selector.label",
      "info": "t:sections.announcement-bar.settings.enable_language_selector.info"
    },
    {
      "type": "header",
      "content": "Custom CSS"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class(es)",
      "info": "Add one or more space-separated CSS classes to the section wrapper."
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "t:sections.announcement-bar.blocks.announcement.settings.text.default",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
