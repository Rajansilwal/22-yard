{%- comment -%}
  22 Yard — Brand Listing
  ---------------------------------------------------------------
  Brands are pulled from the `brand_listing` metaobject:
     • brand_image  (Image / File)
     • brand_name   (Single line text)
     • brand_url    (URL)
     • order        (Integer)   -> used for sorting

  Grid by default. Switch to "Slider" when you have lots of brands —
  the slider shows TWO rows per view (Swiper grid).

  NOTE: If your metaobject type isn't literally `brand_listing`,
  change it in the `assign brands = ...` line below.
{%- endcomment -%}

{%- liquid
  assign uid    = section.id
  assign mode   = section.settings.display_mode
  assign cols_d = section.settings.columns_desktop
  assign cols_t = section.settings.columns_tablet
  assign cols_m = section.settings.columns_mobile
  assign gap    = section.settings.grid_gap

  # ---- Pull + order the brand entries ----
  assign brands = shop.metaobjects.brand_listing.values | sort: 'order'

  assign show_arrows = false
  if section.settings.arrows_desktop or section.settings.arrows_mobile
    assign show_arrows = true
  endif
  assign show_pagination = false
  if section.settings.pagination_desktop or section.settings.pagination_mobile
    assign show_pagination = true
  endif
-%}

{%- if mode == 'slider' -%}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
{%- endif -%}

<style>
  /* ---------- Header ---------- */
  #bl-{{ uid }} .bl-header{
    display:flex; align-items:center; justify-content:space-between;
    gap:1.5rem; margin-bottom:2.4rem;
  }
  #bl-{{ uid }} .bl-eyebrow{
    display:block; margin:0 0 .4rem; font-size:.8rem; font-weight:700;
    letter-spacing:.12em; text-transform:uppercase; color:#8a2b2b;
  }
  #bl-{{ uid }} .bl-heading{
    margin:0; font-family:var(--font-heading-family); font-weight:800;
    line-height:1.05; color:#16161a; font-size:2.6rem;
  }
  #bl-{{ uid }} .bl-viewall{
    flex-shrink:0; display:inline-block; background:#fff;
    border:1.5px solid #16161a; color:#16161a; text-decoration:none;
    text-transform:uppercase; font-weight:700; letter-spacing:.08em;
    font-size:.85rem; padding:.7rem 1.4rem; border-radius:4px;
    transition:background .15s, color .15s;
  }
  #bl-{{ uid }} .bl-viewall:hover{ background:#16161a; color:#fff; }
  @media screen and (max-width:749px){
    #bl-{{ uid }} .bl-header{ flex-direction:column; align-items:flex-start; }
    #bl-{{ uid }} .bl-heading{ font-size:1.8rem; }
  }

  /* ---------- Brand card ---------- */
  #bl-{{ uid }} .bl-card{
    display:flex; align-items:center; justify-content:center;
    background:#fff; border:1px solid #e7e7e7; border-radius:8px;
    box-shadow:0 1px 3px rgba(22,22,26,.06);
    aspect-ratio:3 / 2; padding:1.6rem;
    text-decoration:none; color:inherit;
    transition:box-shadow .2s ease, border-color .2s ease;
  }
  #bl-{{ uid }} .bl-card:hover{
    box-shadow:0 4px 14px rgba(22,22,26,.10); border-color:#d8d8d8;
  }
  #bl-{{ uid }} .bl-card__img{
    max-width:100%; max-height:100%; object-fit:contain;
    {% if section.settings.logo_grayscale %}filter:grayscale(100%); opacity:.75; transition:filter .25s ease, opacity .25s ease;{% endif %}
  }
  {% if section.settings.logo_grayscale %}#bl-{{ uid }} .bl-card:hover .bl-card__img{ filter:none; opacity:1; }{% endif %}
  #bl-{{ uid }} .bl-card__name{ font-weight:700; font-size:1.4rem; text-align:center; color:#16161a; }

  /* ---------- Grid ---------- */
  #bl-{{ uid }} .bl-grid{
    display:grid; gap:{{ gap }}px;
    grid-template-columns:repeat({{ cols_m }}, minmax(0,1fr));
  }
  @media screen and (min-width:750px){
    #bl-{{ uid }} .bl-grid{ grid-template-columns:repeat({{ cols_t }}, minmax(0,1fr)); }
  }
  @media screen and (min-width:990px){
    #bl-{{ uid }} .bl-grid{ grid-template-columns:repeat({{ cols_d }}, minmax(0,1fr)); }
  }

  /* ---------- Slider ---------- */
  #bl-{{ uid }} .bl-slider-wrap{
    position:relative;
    {% if show_arrows %}padding:0 {{ section.settings.arrow_gutter }}px;{% endif %}
  }
  #bl-{{ uid }} .swiper.bl-swiper{ width:100%; overflow:hidden; position:relative; }
  #bl-{{ uid }} .swiper.bl-swiper .swiper-slide{ height:auto; box-sizing:border-box; }

  #bl-{{ uid }} .bl-arrow{
    position:absolute; top:50%; z-index:10; width:4rem; height:4rem;
    display:flex; align-items:center; justify-content:center;
    background:rgb(var(--color-background));
    border:.1rem solid rgba(var(--color-foreground),.15);
    border-radius:50%; cursor:pointer; color:rgb(var(--color-foreground));
    padding:0; transition:background .15s, border-color .15s, opacity .15s;
  }
  #bl-{{ uid }} .bl-arrow:hover{ background:rgba(var(--color-foreground),.06); border-color:rgba(var(--color-foreground),.3); }
  #bl-{{ uid }} .bl-arrow.swiper-button-disabled,
  #bl-{{ uid }} .bl-arrow.swiper-button-lock{ opacity:.3; cursor:default; pointer-events:none; }
  #bl-{{ uid }} .bl-arrow--prev{ left:0; transform:translate(-50%,-50%); }
  #bl-{{ uid }} .bl-arrow--next{ right:0; transform:translate(50%,-50%); }
  #bl-{{ uid }} .bl-arrow svg{ width:1.4rem; height:1.4rem; display:block; }
  #bl-{{ uid }} .bl-arrow--prev svg{ transform:rotate(180deg); }
  #bl-{{ uid }} .bl-arrow::after,
  #bl-{{ uid }} .bl-arrow::before{ content:none !important; display:none !important; }

  #bl-{{ uid }} .swiper.bl-swiper .swiper-pagination{
    position:static; margin-top:1.6rem; display:flex; justify-content:center;
    align-items:center; gap:.5rem; width:100%;
  }
  #bl-{{ uid }} .swiper.bl-swiper .swiper-pagination-bullet{ background:rgb(var(--color-foreground)); opacity:.35; }
  #bl-{{ uid }} .swiper.bl-swiper .swiper-pagination-bullet-active{ background:rgb(var(--color-base-accent-1, var(--color-foreground))); opacity:1; }

  {%- unless section.settings.arrows_desktop -%}
  @media (min-width:750px){ #bl-{{ uid }} .bl-arrow{ display:none !important; } #bl-{{ uid }} .bl-slider-wrap{ padding-left:0; padding-right:0; } }
  {%- endunless -%}
  {%- unless section.settings.arrows_mobile -%}
  @media (max-width:749px){ #bl-{{ uid }} .bl-arrow{ display:none !important; } #bl-{{ uid }} .bl-slider-wrap{ padding-left:0; padding-right:0; } }
  {%- endunless -%}
  {%- unless section.settings.pagination_desktop -%}
  @media (min-width:750px){ #bl-{{ uid }} .swiper-pagination{ display:none !important; } }
  {%- endunless -%}
  {%- unless section.settings.pagination_mobile -%}
  @media (max-width:749px){ #bl-{{ uid }} .swiper-pagination{ display:none !important; } }
  {%- endunless -%}

  #bl-{{ uid }} .bl-empty{ text-align:center; padding:4rem 2rem; color:rgba(var(--color-foreground),.6); }
</style>

<div class="color-{{ section.settings.color_scheme }} gradient" id="bl-{{ uid }}">
  <div class="page-width section-{{ uid }}-padding">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.button_label != blank -%}
      <div class="bl-header">
        <div class="bl-header__text">
          {%- if section.settings.eyebrow != blank -%}<span class="bl-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
          {%- if section.settings.heading != blank -%}<h2 class="bl-heading">{{ section.settings.heading }}</h2>{%- endif -%}
        </div>
        {%- if section.settings.button_label != blank -%}
          <a class="bl-viewall" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if brands.size > 0 -%}
      {%- if mode == 'slider' -%}
        <div class="bl-slider-wrap">
          {%- if show_arrows -%}
            <button type="button" class="bl-arrow bl-arrow--prev" aria-label="Previous">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <button type="button" class="bl-arrow bl-arrow--next" aria-label="Next">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          {%- endif -%}
          <div class="swiper bl-swiper" id="bl-swiper-{{ uid }}">
            <div class="swiper-wrapper">
              {%- for brand in brands -%}
                {%- assign brand_img = brand.brand_image.value -%}
                <div class="swiper-slide">
                  <a class="bl-card" href="{{ brand.brand_url.value | default: '#' }}" aria-label="{{ brand.brand_name.value | escape }}">
                    {%- if brand_img != blank -%}
                      {{ brand_img | image_url: width: 400 | image_tag: loading: 'lazy', widths: '100, 200, 300, 400', alt: brand.brand_name.value, class: 'bl-card__img' }}
                    {%- else -%}
                      <span class="bl-card__name">{{ brand.brand_name.value }}</span>
                    {%- endif -%}
                  </a>
                </div>
              {%- endfor -%}
            </div>
            {%- if show_pagination -%}<div class="swiper-pagination"></div>{%- endif -%}
          </div>
        </div>
      {%- else -%}
        <div class="bl-grid">
          {%- for brand in brands -%}
            {%- assign brand_img = brand.brand_image.value -%}
            <a class="bl-card" href="{{ brand.brand_url.value | default: '#' }}" aria-label="{{ brand.brand_name.value | escape }}">
              {%- if brand_img != blank -%}
                {{ brand_img | image_url: width: 400 | image_tag: loading: 'lazy', widths: '100, 200, 300, 400', alt: brand.brand_name.value, class: 'bl-card__img' }}
              {%- else -%}
                <span class="bl-card__name">{{ brand.brand_name.value }}</span>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- else -%}
      {%- if request.design_mode -%}
        <div class="bl-empty">No brands found. Add entries to the <strong>brand_listing</strong> metaobject under Content &rsaquo; Metaobjects (and make sure they're Active).</div>
      {%- endif -%}
    {%- endif -%}

  </div>
</div>

{%- if mode == 'slider' and brands.size > 0 -%}
  <script>
    (function(){
      var ID    = '{{ uid }}';
      var SPV_D = {{ cols_d }};
      var SPV_T = {{ cols_t }};
      var SPV_M = {{ cols_m }};
      var GAP   = {{ gap }};
      var AUTOPLAY = {% if section.settings.autoplay %}{ delay: {{ section.settings.autoplay_speed | times: 1000 }}, disableOnInteraction:false, pauseOnMouseEnter:true }{% else %}false{% endif %};

      // 2-row grid config for a given number of columns (slides-per-view)
      function gridCfg(spv){ return { slidesPerView:spv, slidesPerGroup:spv, grid:{ rows:2, fill:'row' }, spaceBetween:GAP }; }

      function init(){
        if(typeof Swiper==='undefined'){ setTimeout(init,80); return; }
        var el = document.getElementById('bl-swiper-'+ID);
        if(!el) return;
        var wrap = el.closest('.bl-slider-wrap') || el.parentNode;
        if(el._sw){ try{ el._sw.destroy(true,true); }catch(e){} el._sw=null; }

        el._sw = new Swiper(el, Object.assign(gridCfg(SPV_M), {
          loop:false,                 // Swiper grid (2 rows) does NOT support loop
          watchOverflow:true,         // auto-disables nav when there's nothing to slide
          autoplay:AUTOPLAY,
          pagination:{ el: el.querySelector('.swiper-pagination'), clickable:true },
          navigation:{ nextEl: wrap.querySelector('.bl-arrow--next'), prevEl: wrap.querySelector('.bl-arrow--prev') },
          breakpoints:{ 750: gridCfg(SPV_T), 990: gridCfg(SPV_D) }
        }));
      }

      if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', init); } else { init(); }
      document.addEventListener('shopify:section:load',    function(e){ if(e.detail.sectionId===ID) init(); });
      document.addEventListener('shopify:section:reorder', function(e){ if(e.detail.sectionId===ID) init(); });
      document.addEventListener('shopify:section:unload',  function(e){
        if(e.detail.sectionId===ID){ var el=document.getElementById('bl-swiper-'+ID); if(el&&el._sw){ try{el._sw.destroy(true,true);}catch(ex){} el._sw=null; } }
      });
    })();
  </script>
{%- endif -%}

{%- style -%}
  .section-{{ uid }}-padding{
    padding-top:{{ section.settings.padding_top_mobile }}px;
    padding-bottom:{{ section.settings.padding_bottom_mobile }}px;
  }
  @media screen and (min-width:750px){
    .section-{{ uid }}-padding{
      padding-top:{{ section.settings.padding_top }}px;
      padding-bottom:{{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "22 Yard Brand Listing",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "paragraph", "content": "Brands come from the 'brand_listing' metaobject and are sorted by the Order field. Manage entries under Content > Metaobjects." },

    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop By" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Brands" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View All" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "display_mode", "label": "Display mode",
      "info": "Slider shows 2 rows per view — use it when you have a lot of brands.",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider (2 rows)" }
      ],
      "default": "grid"
    },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 10, "step": 1, "label": "Columns / slides — desktop", "default": 8 },
    { "type": "range", "id": "columns_tablet",  "min": 2, "max": 8,  "step": 1, "label": "Columns / slides — tablet",  "default": 4 },
    { "type": "range", "id": "columns_mobile",  "min": 1, "max": 5,  "step": 1, "label": "Columns / slides — mobile",  "default": 2 },
    { "type": "range", "id": "grid_gap", "min": 0, "max": 48, "step": 2, "unit": "px", "label": "Gap", "default": 16 },

    { "type": "header", "content": "Logos" },
    { "type": "checkbox", "id": "logo_grayscale", "label": "Grayscale logos (color on hover)", "default": false },

    { "type": "header", "content": "Slider options" },
    { "type": "checkbox", "id": "arrows_desktop", "label": "Arrows on desktop & tablet", "default": true },
    { "type": "checkbox", "id": "arrows_mobile", "label": "Arrows on mobile", "default": false },
    { "type": "checkbox", "id": "pagination_desktop", "label": "Pagination on desktop & tablet", "default": false },
    { "type": "checkbox", "id": "pagination_mobile", "label": "Pagination on mobile", "default": true },
    { "type": "range", "id": "arrow_gutter", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Arrow side spacing", "default": 56 },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": false },
    { "type": "range", "id": "autoplay_speed", "min": 2, "max": 10, "step": 1, "unit": "s", "label": "Autoplay speed", "default": 4 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top (desktop)", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom (desktop)", "default": 40 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top (mobile)", "default": 28 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom (mobile)", "default": 28 }
  ],
  "presets": [
    { "name": "22 Yard Brand Listing" }
  ]
}
{% endschema %}
