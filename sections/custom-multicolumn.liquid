{% comment %}
  Custom Multicolumn — Grid + Swiper carousel
  Layout switchable in the customizer:
    - "grid"   : responsive CSS grid, columns set per breakpoint
    - "swiper" : Swiper.js carousel with arrows, pagination, and
                 slides-per-view limits per breakpoint
  Fully responsive. All copy, colors, and columns are editable.
  Each card supports an optional button (uses theme button styles).
{% endcomment %}

{%- liquid
  assign s = section.settings
  assign sid = section.id
-%}

{% style %}
  .multicolumn-{{ sid }} {
    padding: {{ s.padding_top }}px 0 {{ s.padding_bottom }}px;
    background-color: {{ s.background_color }};
    color: {{ s.text_color }};
  }
  .multicolumn-{{ sid }} .multicolumn__container {
    max-width: {{ s.container_width }}px;
    margin: 0 auto;
    padding: 0 16px;
  }
  .multicolumn-{{ sid }} .multicolumn__heading {
    text-align: center;
    font-size: {{ s.heading_size }}px;
    margin: 0 0 12px;
    color: {{ s.heading_color }};
  }
  .multicolumn-{{ sid }} .multicolumn__highlight { color: {{ s.highlight_color }}; }
  .multicolumn-{{ sid }} .multicolumn__intro,
  .multicolumn-{{ sid }} .multicolumn__footer {
    text-align: center;
    font-size: {{ s.text_size }}px;
    max-width: 800px;
    margin-left: auto; margin-right: auto;
    line-height: 1.6;
  }
  .multicolumn-{{ sid }} .multicolumn__intro { margin-bottom: 32px; }
  .multicolumn-{{ sid }} .multicolumn__footer { margin-top: 32px; }

  /* ---------- Card (shared by both layouts) ---------- */
  .multicolumn-{{ sid }} .multicolumn__card {
    background-color: {{ s.card_background }};
    border-radius: {{ s.card_radius }}px;
    overflow: hidden;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.12);
    border: 1px solid {{ s.card_border_color }};
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .multicolumn-{{ sid }} .multicolumn__imgwrap {
    aspect-ratio: {{ s.image_ratio | default: '4/3' | replace: '/', ' / ' }};
    overflow: hidden;
    background: {{ s.card_border_color }};
  }
  .multicolumn-{{ sid }} .multicolumn__card img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform .4s ease;
  }
  .multicolumn-{{ sid }} .multicolumn__card:hover img { transform: scale(1.05); }
  .multicolumn-{{ sid }} .multicolumn__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: {{ s.card_border_color }};
  }
  .multicolumn-{{ sid }} .multicolumn__placeholder-svg {
    width: 45%; height: 45%; opacity: 0.45; fill: {{ s.highlight_color }};
  }
  .multicolumn-{{ sid }} .multicolumn__content {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
  }
  .multicolumn-{{ sid }} .multicolumn__title {
    color: {{ s.heading_color }};
    font-size: {{ s.card_heading_size }}px;
    margin: 0 0 10px; line-height: 1.3;
  }
  .multicolumn-{{ sid }} .multicolumn__text {
    margin: 0; font-size: {{ s.card_text_size }}px; line-height: 1.5;
  }
  .multicolumn-{{ sid }} .multicolumn__button-wrap { margin-top: auto; padding-top: 16px; }

  /* ---------- GRID layout ---------- */
  .multicolumn-{{ sid }} .multicolumn__grid {
    display: grid;
    grid-template-columns: repeat({{ s.grid_columns }}, 1fr);
    gap: 20px;
  }

  /* ---------- SWIPER layout ---------- */
  .multicolumn-{{ sid }} .multicolumn__swiper { position: relative; padding: 0 4px 4px; }
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper { overflow: hidden; }
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-slide { height: auto; }

  /* Pre-init layout to prevent full-width flash before Swiper loads (FOUC) */
  .multicolumn-{{ sid }} .swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    gap: 16px;
  }
  .multicolumn-{{ sid }} .swiper:not(.swiper-initialized) .swiper-slide {
    flex: 0 0 calc((100% - 16px * ({{ s.slides_mobile }} - 1)) / {{ s.slides_mobile }});
  }
  @media screen and (min-width: 768px) {
    .multicolumn-{{ sid }} .swiper:not(.swiper-initialized) .swiper-slide {
      flex-basis: calc((100% - 18px * ({{ s.slides_tablet }} - 1)) / {{ s.slides_tablet }});
    }
  }
  @media screen and (min-width: 1024px) {
    .multicolumn-{{ sid }} .swiper:not(.swiper-initialized) .swiper-slide {
      flex-basis: calc((100% - 20px * ({{ s.slides_desktop }} - 1)) / {{ s.slides_desktop }});
    }
  }

  /* Arrows */
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-next,
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-prev {
    color: {{ s.arrow_icon_color }};
    background: {{ s.arrow_background }};
    width: 36px; height: 36px; border-radius: 50%;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    transition: transform .18s ease, opacity .18s ease;
    margin-top: -34px; /* lift to vertical center of the image area */
  }
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-next:hover,
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-prev:hover { transform: scale(1.08); }
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-next:after,
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-prev:after { display: none; }
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-next svg,
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-prev svg {
    display: block; width: 15px; height: 15px; color: {{ s.arrow_icon_color }};
  }
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-disabled { opacity: 0.35; }
  /* Arrow visibility per device */
  {% unless s.show_arrows_desktop %}
    @media screen and (min-width: 769px) {
      .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-next,
      .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-prev { display: none; }
    }
  {% endunless %}
  {% unless s.show_arrows_mobile %}
    @media screen and (max-width: 768px) {
      .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-next,
      .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-prev { display: none !important; }
    }
  {% endunless %}

  /* Pagination */
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-pagination {
    position: static; margin-top: 18px;
  }
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-pagination-bullet {
    background: {{ s.text_color }}; opacity: 0.4;
    width: 9px; height: 9px; transition: opacity .2s, transform .2s;
  }
  .multicolumn-{{ sid }} .multicolumn__swiper .swiper-pagination-bullet-active {
    background: {{ s.highlight_color }}; opacity: 1; transform: scale(1.25);
  }
  /* Pagination visibility per device */
  {% unless s.show_pagination_desktop %}
    @media screen and (min-width: 769px) {
      .multicolumn-{{ sid }} .multicolumn__swiper .swiper-pagination { display: none; }
    }
  {% endunless %}
  {% unless s.show_pagination_mobile %}
    @media screen and (max-width: 768px) {
      .multicolumn-{{ sid }} .multicolumn__swiper .swiper-pagination { display: none !important; }
    }
  {% endunless %}

  /* ---------- Responsive ---------- */
  @media screen and (max-width: 1024px) {
    .multicolumn-{{ sid }} .multicolumn__grid {
      grid-template-columns: repeat({{ s.grid_columns_tablet }}, 1fr);
    }
  }
  @media screen and (max-width: 768px) {
    .multicolumn-{{ sid }} .multicolumn__heading { font-size: {{ s.mobile_heading_size }}px; }
    .multicolumn-{{ sid }} .multicolumn__intro,
    .multicolumn-{{ sid }} .multicolumn__footer { font-size: {{ s.mobile_text_size }}px; }
    .multicolumn-{{ sid }} .multicolumn__grid {
      grid-template-columns: repeat({{ s.grid_columns_mobile }}, 1fr);
    }
    .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-next,
    .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-prev {
      width: 32px; height: 32px; margin-top: -26px;
    }
    .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-next svg,
    .multicolumn-{{ sid }} .multicolumn__swiper .swiper-button-prev svg { width: 13px; height: 13px; }
  }
{% endstyle %}

{%- if s.layout == "swiper" -%}
  {% comment %} Load Swiper only when the carousel layout is active {% endcomment %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
{%- endif -%}

<section id="multicolumn-{{ sid }}" class="multicolumn-{{ sid }} multicolumn-section {{ section.settings.custom_class }}">
  <div class="multicolumn__container">

    {%- if s.heading != blank -%}
      <h2 class="multicolumn__heading">
        {{ s.heading }}
        {%- if s.highlight_text != blank -%}
          <span class="multicolumn__highlight">{{ s.highlight_text }}</span>
        {%- endif -%}
      </h2>
    {%- endif -%}

    {%- if s.intro_text != blank -%}
      <div class="multicolumn__intro">{{ s.intro_text }}</div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}

      {%- capture cards_html -%}
        {%- for block in section.blocks -%}
          {%- assign bs = block.settings -%}
          <div class="multicolumn__card" {{ block.shopify_attributes }}>
            <div class="multicolumn__imgwrap">
              {%- if bs.image != blank -%}
                <img
                  src="{{ bs.image | image_url: width: 900 }}"
                  srcset="{{ bs.image | image_url: width: 450 }} 450w, {{ bs.image | image_url: width: 900 }} 900w"
                  sizes="(max-width: 768px) 100vw, 33vw"
                  alt="{{ bs.image_alt | escape }}"
                  loading="lazy" width="900" height="675"
                >
              {%- elsif bs.external_image_url != blank -%}
                <img src="{{ bs.external_image_url }}" alt="{{ bs.image_alt | escape }}" loading="lazy">
              {%- elsif s.placeholder_image != blank -%}
                <img src="{{ s.placeholder_image | image_url: width: 900 }}" alt="{{ bs.image_alt | escape }}" loading="lazy" width="900" height="675">
              {%- elsif s.placeholder_url != blank -%}
                <img src="{{ s.placeholder_url }}" alt="{{ bs.image_alt | escape }}" loading="lazy">
              {%- else -%}
                <div class="multicolumn__placeholder">
                  {{ 'image' | placeholder_svg_tag: 'multicolumn__placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
            <div class="multicolumn__content">
              {%- if bs.card_heading != blank -%}
                <h3 class="multicolumn__title">{{ bs.card_heading }}</h3>
              {%- endif -%}
              {%- if bs.card_text != blank -%}
                <div class="multicolumn__text">{{ bs.card_text }}</div>
              {%- endif -%}
              {%- if bs.button_label != blank -%}
                <div class="multicolumn__button-wrap">
                  <a
                    {% if bs.button_link != blank %}href="{{ bs.button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
                    class="{% if bs.button_style == 'link' %}link underlined-link{% else %}btn btn--{{ bs.button_style }} button button--{{ bs.button_style }}{% endif %}"
                  >
                    {{- bs.button_label | escape -}}
                  </a>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endcapture -%}

      {%- if s.layout == "swiper" -%}
        <div class="multicolumn__swiper" id="multicolumn-swiper-{{ sid }}">
          <div class="swiper">
            <div class="swiper-wrapper">
              {%- for block in section.blocks -%}
                {%- assign bs = block.settings -%}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  <div class="multicolumn__card">
                    <div class="multicolumn__imgwrap">
                      {%- if bs.image != blank -%}
                        <img
                          src="{{ bs.image | image_url: width: 900 }}"
                          srcset="{{ bs.image | image_url: width: 450 }} 450w, {{ bs.image | image_url: width: 900 }} 900w"
                          sizes="(max-width: 768px) 90vw, 33vw"
                          alt="{{ bs.image_alt | escape }}"
                          loading="lazy" width="900" height="675"
                        >
                      {%- elsif bs.external_image_url != blank -%}
                        <img src="{{ bs.external_image_url }}" alt="{{ bs.image_alt | escape }}" loading="lazy">
                      {%- elsif s.placeholder_image != blank -%}
                        <img src="{{ s.placeholder_image | image_url: width: 900 }}" alt="{{ bs.image_alt | escape }}" loading="lazy" width="900" height="675">
                      {%- elsif s.placeholder_url != blank -%}
                        <img src="{{ s.placeholder_url }}" alt="{{ bs.image_alt | escape }}" loading="lazy">
                      {%- else -%}
                        <div class="multicolumn__placeholder">
                          {{ 'image' | placeholder_svg_tag: 'multicolumn__placeholder-svg' }}
                        </div>
                      {%- endif -%}
                    </div>
                    <div class="multicolumn__content">
                      {%- if bs.card_heading != blank -%}
                        <h3 class="multicolumn__title">{{ bs.card_heading }}</h3>
                      {%- endif -%}
                      {%- if bs.card_text != blank -%}
                        <div class="multicolumn__text">{{ bs.card_text }}</div>
                      {%- endif -%}
                      {%- if bs.button_label != blank -%}
                        <div class="multicolumn__button-wrap">
                          <a
                            {% if bs.button_link != blank %}href="{{ bs.button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
                            class="{% if bs.button_style == 'link' %}link underlined-link{% else %}btn btn--{{ bs.button_style }} button button--{{ bs.button_style }}{% endif %}"
                          >
                            {{- bs.button_label | escape -}}
                          </a>
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
            {%- if s.show_pagination_desktop or s.show_pagination_mobile -%}<div class="swiper-pagination"></div>{%- endif -%}
          </div>
          {%- if s.show_arrows_desktop or s.show_arrows_mobile -%}
            <div class="swiper-button-prev" aria-label="Previous">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="swiper-button-next" aria-label="Next">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          {%- endif -%}
        </div>

        <script>
          (function () {
            function initMulticolumnSwiper() {
              if (typeof Swiper === 'undefined') { return setTimeout(initMulticolumnSwiper, 60); }
              var el = document.querySelector('#multicolumn-swiper-{{ sid }} .swiper');
              if (!el || el.dataset.inited) return;
              el.dataset.inited = '1';
              new Swiper(el, {
                slidesPerView: {{ s.slides_mobile }},
                slidesPerGroup: {% if s.dots_per_page %}{{ s.slides_mobile }}{% else %}1{% endif %},
                spaceBetween: 16,
                // Loop is disabled automatically when "one dot per page" is on,
                // because looping clones slides and breaks page counting.
                loop: {% if s.loop and s.dots_per_page == false %}true{% else %}false{% endif %},
                autoplay: {% if s.autoplay %}{ delay: {{ s.autoplay_speed | times: 1000 }}, disableOnInteraction: false }{% else %}false{% endif %},
                pagination: {
                  el: '#multicolumn-swiper-{{ sid }} .swiper-pagination',
                  clickable: true,
                  dynamicBullets: false
                },
                navigation: {
                  nextEl: '#multicolumn-swiper-{{ sid }} .swiper-button-next',
                  prevEl: '#multicolumn-swiper-{{ sid }} .swiper-button-prev'
                },
                breakpoints: {
                  768:  {
                    slidesPerView: {{ s.slides_tablet }},
                    slidesPerGroup: {% if s.dots_per_page %}{{ s.slides_tablet }}{% else %}1{% endif %},
                    spaceBetween: 18
                  },
                  1024: {
                    slidesPerView: {{ s.slides_desktop }},
                    slidesPerGroup: {% if s.dots_per_page %}{{ s.slides_desktop }}{% else %}1{% endif %},
                    spaceBetween: 20
                  }
                }
              });
            }
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', initMulticolumnSwiper);
            } else { initMulticolumnSwiper(); }
            // Reinit inside the theme editor when blocks change
            if (window.Shopify && Shopify.designMode) {
              document.addEventListener('shopify:section:load', initMulticolumnSwiper);
            }
          })();
        </script>

      {%- else -%}
        <div class="multicolumn__grid">{{ cards_html }}</div>
      {%- endif -%}

    {%- endif -%}

    {%- if s.footer_text != blank -%}
      <div class="multicolumn__footer">{{ s.footer_text }}</div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Custom Multicolumn",
  "tag": "section",
  "class": "custom-multicolumn-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout style",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "swiper", "label": "Carousel (Swiper)" }
      ],
      "default": "swiper"
    },

    { "type": "header", "content": "Grid columns" },
    { "type": "range", "id": "grid_columns", "label": "Desktop columns", "min": 1, "max": 5, "step": 1, "default": 3 },
    { "type": "range", "id": "grid_columns_tablet", "label": "Tablet columns", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "grid_columns_mobile", "label": "Mobile columns", "min": 1, "max": 3, "step": 1, "default": 1 },

    { "type": "header", "content": "Carousel (Swiper) options" },
    { "type": "range", "id": "slides_desktop", "label": "Slides per view — desktop", "min": 1, "max": 5, "step": 1, "default": 3 },
    { "type": "range", "id": "slides_tablet", "label": "Slides per view — tablet", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "slides_mobile", "label": "Slides per view — mobile", "min": 1, "max": 3, "step": 1, "default": 1 },
    { "type": "checkbox", "id": "show_arrows_desktop", "label": "Show arrows on desktop", "default": true },
    { "type": "checkbox", "id": "show_arrows_mobile", "label": "Show arrows on mobile", "default": false },
    { "type": "checkbox", "id": "show_pagination_desktop", "label": "Show pagination dots on desktop", "default": true },
    { "type": "checkbox", "id": "show_pagination_mobile", "label": "Show pagination dots on mobile", "default": true },
    { "type": "checkbox", "id": "dots_per_page", "label": "One dot per page (group slides)", "info": "On: dots = number of pages (e.g. 4 slides / 3 per view = 2 dots). Off: one dot per slide. Looping is disabled when this is on.", "default": true },
    { "type": "checkbox", "id": "loop", "label": "Loop slides", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": false },
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay delay", "min": 2, "max": 10, "step": 1, "unit": "s", "default": 4 },

    { "type": "header", "content": "Main content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Section heading" },
    { "type": "text", "id": "highlight_text", "label": "Highlighted heading text" },
    { "type": "richtext", "id": "intro_text", "label": "Intro text", "default": "<p>Add a short introduction to describe what this section is about.</p>" },
    { "type": "richtext", "id": "footer_text", "label": "Bottom text" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#121212" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#121212" },
    { "type": "color", "id": "highlight_color", "label": "Highlight color", "default": "#1773b0" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border_color", "label": "Card border color", "default": "#e3e3e3" },
    { "type": "color", "id": "arrow_background", "label": "Arrow background", "default": "#121212" },
    { "type": "color", "id": "arrow_icon_color", "label": "Arrow icon color", "default": "#ffffff" },

    { "type": "header", "content": "Default / placeholder image", "info": "Shown on any column that has no image and no external URL." },
    { "type": "image_picker", "id": "placeholder_image", "label": "Default image (upload)" },
    { "type": "text", "id": "placeholder_url", "label": "Default image URL", "info": "Used if no upload above. If both are empty, a built-in placeholder graphic is shown." },

    { "type": "header", "content": "Sizing" },
    {
      "type": "select", "id": "image_ratio", "label": "Image aspect ratio",
      "options": [
        { "value": "4/3", "label": "Landscape (4:3)" },
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "16/9", "label": "Wide (16:9)" },
        { "value": "3/2", "label": "Photo (3:2)" },
        { "value": "2/3", "label": "Tall (2:3)" }
      ],
      "default": "4/3"
    },
    { "type": "range", "id": "container_width", "label": "Container width", "min": 800, "max": 1600, "step": 50, "default": 1200 },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "card_radius", "label": "Card border radius", "min": 0, "max": 40, "step": 2, "default": 8 },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 20, "max": 60, "step": 2, "unit": "px", "default": 32 },
    { "type": "range", "id": "mobile_heading_size", "label": "Mobile heading size", "min": 18, "max": 44, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 18 },
    { "type": "range", "id": "mobile_text_size", "label": "Mobile text size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "card_heading_size", "label": "Card heading size", "min": 16, "max": 34, "step": 1, "unit": "px", "default": 20 },
    { "type": "range", "id": "card_text_size", "label": "Card text size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },
    {
      "type": "header",
      "content": "Custom CSS"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class(es)",
      "info": "Add one or more space-separated CSS classes to the section wrapper."
    }
