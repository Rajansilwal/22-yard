{% comment %}
  Renders the desktop mega/dropdown nav.
  Per-item overrides are set via "menu_item_override" blocks in the header section.

  Accepts:
  - blocks: section.blocks

  Match strategy: compare link.title | handleize  OR  link.url last path segment
  against block.settings.menu_item_handle (entered by merchant).
{% endcomment %}

{%- liquid
  assign default_type = section.settings.menu_type_desktop | default: 'mega'
-%}

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">

    {%- for link in section.settings.menu.links -%}

      {%- liquid
        # ── Resolve override block for this link ──────────────────────────
        assign item_type              = default_type
        assign item_mega_layout       = 'columns'
        assign item_mega_columns      = 4
        assign item_mega_image        = nil
        assign item_mega_heading      = nil
        assign item_mega_link         = nil
        assign item_show_desc         = false
        assign item_icon_image        = nil
        assign item_icon_show         = false
        assign item_collection_handle = nil
        assign item_product_handle    = nil
        assign item_slider_enable     = false
        assign item_promo_image       = nil
        assign item_promo_heading     = nil
        assign item_promo_text        = nil
        assign item_promo_link        = nil

        # Build candidates: title handleized + last URL segment
        assign link_handle_title = link.title | handleize
        assign link_url_parts    = link.url | split: '/'
        assign link_handle_url   = link_url_parts | last | downcase

        for block in blocks
          if block.type == 'menu_item_override'
            assign bh = block.settings.menu_item_handle | strip | downcase
            assign bh_match = false
            if bh != blank
              if bh == link_handle_title
                assign bh_match = true
              endif
              if bh == link_handle_url
                assign bh_match = true
              endif
              if bh == link.handle
                assign bh_match = true
              endif
            endif
            if bh_match
              if block.settings.menu_type != 'default'
                assign item_type = block.settings.menu_type
              endif
              assign item_mega_layout       = block.settings.mega_layout       | default: 'columns'
              assign item_mega_columns      = block.settings.mega_columns       | default: 4
              assign item_mega_image        = block.settings.mega_featured_image
              assign item_mega_heading      = block.settings.mega_featured_heading
              assign item_mega_link         = block.settings.mega_featured_link
              assign item_show_desc         = block.settings.mega_show_description
              assign item_icon_image        = block.settings.item_icon_image
              assign item_icon_show         = block.settings.item_show_icon
              assign item_collection_handle = block.settings.mega_collection_handle
              assign item_product_handle    = block.settings.mega_product_handle
              assign item_slider_enable     = block.settings.mega_slider_enable
              assign item_promo_image       = block.settings.promo_image
              assign item_promo_heading     = block.settings.promo_heading
              assign item_promo_text        = block.settings.promo_text
              assign item_promo_link        = block.settings.promo_link
              break
            endif
          endif
        endfor

        # Resolve collection / product objects
        assign mega_collection = nil
        assign mega_product    = nil
        if item_collection_handle != blank
          assign mega_collection = collections[item_collection_handle]
        endif
        if item_product_handle != blank
          assign mega_product = all_products[item_product_handle]
        endif
      -%}

      <li class="header__nav-item">

        {%- comment -%} ── Nav item trigger label ── {%- endcomment -%}
        {%- if link.links != blank and item_type != 'none' -%}

          {%- if item_type == 'dropdown' -%}
            {%- comment -%}════════════════ DROPDOWN ════════════════{%- endcomment -%}
            <header-menu>
              <details id="Details-HeaderMenu-{{ forloop.index }}">
                <summary
                  id="HeaderMenu-{{ link.handle }}"
                  class="header__menu-item list-menu__item link focus-inset"
                >
                  {%- if item_icon_show and item_icon_image != blank -%}
                    <span class="header__menu-icon">
                      {{- item_icon_image | image_url: width: 24 | image_tag: width: 24, height: 24, loading: 'lazy' -}}
                    </span>
                  {%- endif -%}
                  <span {%- if link.child_active %} class="header__active-menu-item"{% endif %}>
                    {{- link.title | escape -}}
                  </span>
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </summary>
                <ul
                  id="HeaderMenu-MenuList-{{ forloop.index }}"
                  class="header__submenu list-menu list-menu--disclosure color-{{ section.settings.menu_color_scheme }} gradient caption-large motion-reduce global-settings-popup"
                  role="list"
                  tabindex="-1"
                >
                  {%- for childlink in link.links -%}
                    <li>
                      {%- if childlink.links == blank -%}
                        <a
                          id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                          href="{{ childlink.url }}"
                          class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if childlink.current %} list-menu__item--active{% endif %}"
                          {% if childlink.current %}aria-current="page"{% endif %}
                        >{{ childlink.title | escape }}</a>
                      {%- else -%}
                        <details id="Details-HeaderSubMenu-{{ link.handle }}-{{ childlink.handle }}">
                          <summary
                            id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                            class="header__menu-item link link--text list-menu__item focus-inset caption-large"
                          >
                            <span>{{ childlink.title | escape }}</span>
                            {{- 'icon-caret.svg' | inline_asset_content -}}
                          </summary>
                          <ul class="header__submenu list-menu motion-reduce">
                            {%- for grandchildlink in childlink.links -%}
                              <li>
                                <a
                                  href="{{ grandchildlink.url }}"
                                  class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if grandchildlink.current %} list-menu__item--active{% endif %}"
                                  {% if grandchildlink.current %}aria-current="page"{% endif %}
                                >{{ grandchildlink.title | escape }}</a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </details>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </details>
            </header-menu>

          {%- else -%}
            {%- comment -%}════════════════ MEGA MENU ════════════════{%- endcomment -%}
            <header-menu>
              <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">
                <summary
                  id="HeaderMenu-{{ link.handle }}"
                  class="header__menu-item list-menu__item link focus-inset"
                >
                  {%- if item_icon_show and item_icon_image != blank -%}
                    <span class="header__menu-icon">
                      {{- item_icon_image | image_url: width: 24 | image_tag: width: 24, height: 24, loading: 'lazy' -}}
                    </span>
                  {%- endif -%}
                  <span {%- if link.child_active %} class="header__active-menu-item"{% endif %}>
                    {{- link.title | escape -}}
                  </span>
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </summary>

                <div
                  id="MegaMenu-Content-{{ forloop.index }}"
                  class="mega-menu__content mega-menu__content--{{ item_mega_layout }} color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                  tabindex="-1"
                >
                  <div class="mega-menu__inner page-width">

                    {%- comment -%}──────── LAYOUT: columns (default) ────────{%- endcomment -%}
                    {%- if item_mega_layout == 'columns' -%}
                      {%- if item_promo_image != blank or item_mega_image != blank -%}
                        {%- comment -%} Columns + promo panel {%- endcomment -%}
                        <div class="mega-menu__with-promo">
                          <ul
                            class="mega-menu__list mega-menu__list--columns{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                            role="list"
                            style="--mega-columns: {{ item_mega_columns }};"
                          >
                            {%- for childlink in link.links -%}
                              {%- render 'mega-menu-link-item',
                                childlink: childlink,
                                link: link,
                                show_desc: item_show_desc
                              -%}
                            {%- endfor -%}
                          </ul>
                          {%- assign promo_img = item_promo_image | default: item_mega_image -%}
                          {%- assign promo_url = item_promo_link | default: item_mega_link | default: link.url -%}
                          <div class="mega-menu__promo">
                            {%- if promo_img != blank -%}
                              <a href="{{ promo_url }}" class="mega-menu__promo-image-wrap">
                                {{ promo_img | image_url: width: 480 | image_tag: class: 'mega-menu__promo-img', loading: 'lazy' }}
                              </a>
                            {%- endif -%}
                            {%- if item_promo_heading != blank -%}
                              <p class="mega-menu__promo-heading">{{ item_promo_heading }}</p>
                            {%- endif -%}
                            {%- if item_promo_text != blank -%}
                              <p class="mega-menu__promo-text">{{ item_promo_text }}</p>
                            {%- endif -%}
                          </div>
                        </div>
                      {%- else -%}
                        <ul
                          class="mega-menu__list mega-menu__list--columns{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                          role="list"
                          style="--mega-columns: {{ item_mega_columns }};"
                        >
                          {%- for childlink in link.links -%}
                            {%- render 'mega-menu-link-item',
                              childlink: childlink,
                              link: link,
                              show_desc: item_show_desc
                            -%}
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                    {%- comment -%}──────── LAYOUT: icon-links ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'icon-links' -%}
                      <ul class="mega-menu__list mega-menu__list--icons" role="list">
                        {%- for childlink in link.links -%}
                          <li class="mega-menu__icon-item">
                            {%- liquid
                              assign child_img = nil
                              if childlink.object and childlink.object.featured_image
                                assign child_img = childlink.object.featured_image
                              endif
                            -%}
                            <a
                              href="{{ childlink.url }}"
                              class="mega-menu__icon-link link{% if childlink.current %} mega-menu__link--active{% endif %}"
                              {% if childlink.current %}aria-current="page"{% endif %}
                            >
                              {%- if child_img != blank -%}
                                <span class="mega-menu__icon-img-wrap">
                                  {{ child_img | image_url: width: 80 | image_tag: class: 'mega-menu__icon-img', loading: 'lazy', width: 40, height: 40 }}
                                </span>
                              {%- else -%}
                                <span class="mega-menu__icon-placeholder">
                                  <span class="svg-wrapper">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
                                </span>
                              {%- endif -%}
                              <span class="mega-menu__icon-label">{{ childlink.title | escape }}</span>
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>

                    {%- comment -%}──────── LAYOUT: image-links ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'image-links' -%}
                      <ul
                        class="mega-menu__list mega-menu__list--image-links"
                        role="list"
                        style="--mega-columns: {{ item_mega_columns }};"
                      >
                        {%- for childlink in link.links -%}
                          {%- liquid
                            assign card_img = nil
                            if childlink.object and childlink.object.featured_image
                              assign card_img = childlink.object.featured_image
                            endif
                          -%}
                          <li class="mega-menu__image-card">
                            <a
                              href="{{ childlink.url }}"
                              class="mega-menu__image-card-link link{% if childlink.current %} mega-menu__link--active{% endif %}"
                              {% if childlink.current %}aria-current="page"{% endif %}
                            >
                              <div class="mega-menu__image-card-media">
                                {%- if card_img != blank -%}
                                  {{ card_img | image_url: width: 400 | image_tag: class: 'mega-menu__image-card-img', loading: 'lazy' }}
                                {%- else -%}
                                  {{ 'collection-apparel-1' | placeholder_svg_tag: 'mega-menu__image-card-placeholder placeholder-svg' }}
                                {%- endif -%}
                              </div>
                              <span class="mega-menu__image-card-label">{{ childlink.title | escape }}</span>
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>

                    {%- comment -%}──────── LAYOUT: slider (Swiper) ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'slider' -%}
                      {%- assign slider_id = 'MegaSlider-' | append: forloop.index -%}
                      <div class="mega-menu__slider-wrap">
                        <div class="swiper mega-menu__swiper" id="{{ slider_id }}">
                          <ul class="swiper-wrapper mega-menu__list mega-menu__list--slider" role="list" style="--mega-columns: {{ item_mega_columns }};">
                            {%- for childlink in link.links -%}
                              {%- liquid
                                assign slide_img = nil
                                if childlink.object and childlink.object.featured_image
                                  assign slide_img = childlink.object.featured_image
                                endif
                              -%}
                              <li class="swiper-slide mega-menu__slide">
                                <a
                                  href="{{ childlink.url }}"
                                  class="mega-menu__slide-link link{% if childlink.current %} mega-menu__link--active{% endif %}"
                                  {% if childlink.current %}aria-current="page"{% endif %}
                                >
                                  <div class="mega-menu__slide-media">
                                    {%- if slide_img != blank -%}
                                      {{ slide_img | image_url: width: 300 | image_tag: class: 'mega-menu__slide-img', loading: 'lazy' }}
                                    {%- else -%}
                                      {{ 'product-apparel-1' | placeholder_svg_tag: 'mega-menu__slide-placeholder placeholder-svg' }}
                                    {%- endif -%}
                                  </div>
                                  <span class="mega-menu__slide-label">{{ childlink.title | escape }}</span>
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                          <button class="mega-menu__swiper-btn mega-menu__swiper-btn--prev swiper-button-prev" aria-label="Previous"></button>
                          <button class="mega-menu__swiper-btn mega-menu__swiper-btn--next swiper-button-next" aria-label="Next"></button>
                        </div>
                      </div>
                      <script>
                        (function(){
                          function initMegaSwiper() {
                            if (typeof Swiper === 'undefined') { setTimeout(initMegaSwiper, 80); return; }
                            var el = document.getElementById('{{ slider_id }}');
                            if (!el || el._swInit) return;
                            el._swInit = true;
                            new Swiper(el, {
                              slidesPerView: {{ item_mega_columns }},
                              spaceBetween: 16,
                              navigation: { prevEl: el.querySelector('.swiper-button-prev'), nextEl: el.querySelector('.swiper-button-next') },
                              breakpoints: { 0: { slidesPerView: 2 }, 750: { slidesPerView: 3 }, 990: { slidesPerView: {{ item_mega_columns }} } }
                            });
                          }
                          var details = document.getElementById('Details-HeaderMenu-{{ forloop.index }}');
                          if (details) details.addEventListener('toggle', function(){ if (details.open) initMegaSwiper(); }, { once: true });
                        })();
                      </script>

                    {%- comment -%}──────── LAYOUT: featured-product ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'featured-product' -%}
                      <div class="mega-menu__featured-split">
                        {%- comment -%} Left: links from menu {%- endcomment -%}
                        <ul
                          class="mega-menu__list mega-menu__list--columns mega-menu__list--side{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                          role="list"
                          style="--mega-columns: 1;"
                        >
                          {%- for childlink in link.links -%}
                            {%- render 'mega-menu-link-item',
                              childlink: childlink,
                              link: link,
                              show_desc: item_show_desc
                            -%}
                          {%- endfor -%}
                        </ul>
                        {%- comment -%} Right: featured product card {%- endcomment -%}
                        {%- if mega_product != blank -%}
                          <div class="mega-menu__product-card">
                            <a href="{{ mega_product.url }}" class="mega-menu__product-card-link link">
                              {%- if mega_product.featured_image != blank -%}
                                {{ mega_product.featured_image | image_url: width: 400 | image_tag: class: 'mega-menu__product-img', loading: 'lazy' }}
                              {%- endif -%}
                              <div class="mega-menu__product-info">
                                <span class="mega-menu__product-title">{{ mega_product.title | escape }}</span>
                                <span class="mega-menu__product-price">{{ mega_product.price | money }}</span>
                              </div>
                            </a>
                          </div>
                        {%- elsif item_mega_image != blank -%}
                          <div class="mega-menu__promo">
                            <a href="{{ item_mega_link | default: link.url }}" class="mega-menu__promo-image-wrap">
                              {{ item_mega_image | image_url: width: 480 | image_tag: class: 'mega-menu__promo-img', loading: 'lazy' }}
                            </a>
                            {%- if item_mega_heading != blank -%}<p class="mega-menu__promo-heading">{{ item_mega_heading }}</p>{%- endif -%}
                          </div>
                        {%- endif -%}
                      </div>

                    {%- comment -%}──────── LAYOUT: featured-collection ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'featured-collection' -%}
                      <div class="mega-menu__featured-split">
                        {%- comment -%} Left: nav links from menu {%- endcomment -%}
                        <ul
                          class="mega-menu__list mega-menu__list--columns mega-menu__list--side{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                          role="list"
                          style="--mega-columns: 1;"
                        >
                          {%- for childlink in link.links -%}
                            {%- render 'mega-menu-link-item',
                              childlink: childlink,
                              link: link,
                              show_desc: item_show_desc
                            -%}
                          {%- endfor -%}
                        </ul>

                        {%- comment -%} Right: products from collection, slider if overflow {%- endcomment -%}
                        {%- if mega_collection != blank -%}
                          {%- liquid
                            assign fc_limit   = item_mega_columns | at_most: 4
                            assign fc_total   = mega_collection.products_count
                            assign fc_use_slider = false
                            if fc_total > fc_limit
                              assign fc_use_slider = true
                            endif
                            assign fc_slider_id = 'MegaFC-' | append: forloop.index
                          -%}
                          <div class="mega-menu__collection-preview">
                            <p class="mega-menu__collection-title">
                              <a href="{{ mega_collection.url }}" class="mega-menu__collection-title-link link">
                                {{ mega_collection.title | escape }}
                              </a>
                            </p>

                            {%- if fc_use_slider -%}
                              <div class="mega-menu__slider-wrap">
                                <div class="swiper mega-menu__swiper" id="{{ fc_slider_id }}">
                                  <ul class="swiper-wrapper mega-menu__collection-grid" role="list">
                                    {%- for product in mega_collection.products limit: 12 -%}
                                      <li class="swiper-slide">
                                        <a href="{{ product.url }}" class="mega-menu__product-card-link link">
                                          <div class="mega-menu__collection-card-media">
                                            {%- if product.featured_image != blank -%}
                                              {{ product.featured_image | image_url: width: 300 | image_tag: class: 'mega-menu__collection-card-img', loading: 'lazy' }}
                                            {%- else -%}
                                              {{ 'product-apparel-1' | placeholder_svg_tag: 'mega-menu__collection-card-img placeholder-svg' }}
                                            {%- endif -%}
                                          </div>
                                          <span class="mega-menu__product-title">{{ product.title | escape }}</span>
                                          <span class="mega-menu__product-price">{{ product.price | money }}</span>
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                  <button class="mega-menu__swiper-btn mega-menu__swiper-btn--prev swiper-button-prev" aria-label="Previous"></button>
                                  <button class="mega-menu__swiper-btn mega-menu__swiper-btn--next swiper-button-next" aria-label="Next"></button>
                                </div>
                              </div>
                              <script>
                                (function(){
                                  function initFCSwiper(){
                                    if(typeof Swiper==='undefined'){setTimeout(initFCSwiper,80);return;}
                                    var el=document.getElementById('{{ fc_slider_id }}');
                                    if(!el||el._swInit)return;
                                    el._swInit=true;
                                    new Swiper(el,{
                                      slidesPerView:{{ fc_limit }},
                                      spaceBetween:16,
                                      navigation:{prevEl:el.querySelector('.swiper-button-prev'),nextEl:el.querySelector('.swiper-button-next')},
                                      breakpoints:{0:{slidesPerView:2},750:{slidesPerView:3},990:{slidesPerView:{{ fc_limit }}}}
                                    });
                                  }
                                  var det=document.getElementById('Details-HeaderMenu-{{ forloop.index }}');
                                  if(det) det.addEventListener('toggle',function(){if(det.open)initFCSwiper();},{once:true});
                                })();
                              </script>

                            {%- else -%}
                              <ul class="mega-menu__collection-grid" style="--mega-columns: {{ fc_limit }};">
                                {%- for product in mega_collection.products limit: fc_limit -%}
                                  <li>
                                    <a href="{{ product.url }}" class="mega-menu__product-card-link link">
                                      <div class="mega-menu__collection-card-media">
                                        {%- if product.featured_image != blank -%}
                                          {{ product.featured_image | image_url: width: 300 | image_tag: class: 'mega-menu__collection-card-img', loading: 'lazy' }}
                                        {%- else -%}
                                          {{ 'product-apparel-1' | placeholder_svg_tag: 'mega-menu__collection-card-img placeholder-svg' }}
                                        {%- endif -%}
                                      </div>
                                      <span class="mega-menu__product-title">{{ product.title | escape }}</span>
                                      <span class="mega-menu__product-price">{{ product.price | money }}</span>
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      </div>

                    {%- comment -%}──────── LAYOUT: collection-list ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'collection-list' -%}
                      {%- liquid
                        assign cl_total   = link.links | size
                        assign cl_use_slider = false
                        if cl_total > item_mega_columns
                          assign cl_use_slider = true
                        endif
                        assign cl_slider_id = 'MegaCL-' | append: forloop.index
                      -%}

                      {%- if cl_use_slider -%}
                        {%- comment -%} More items than visible columns → Swiper {%- endcomment -%}
                        <div class="mega-menu__slider-wrap">
                          <div class="swiper mega-menu__swiper" id="{{ cl_slider_id }}">
                            <ul class="swiper-wrapper mega-menu__list mega-menu__list--collection-list" role="list">
                              {%- for childlink in link.links -%}
                                {%- liquid
                                  assign cl_img = nil
                                  if childlink.object and childlink.object.featured_image
                                    assign cl_img = childlink.object.featured_image
                                  endif
                                -%}
                                <li class="swiper-slide mega-menu__collection-card">
                                  <a
                                    href="{{ childlink.url }}"
                                    class="mega-menu__collection-card-link link{% if childlink.current %} mega-menu__link--active{% endif %}"
                                    {% if childlink.current %}aria-current="page"{% endif %}
                                  >
                                    <div class="mega-menu__collection-card-media">
                                      {%- if cl_img != blank -%}
                                        {{ cl_img | image_url: width: 300 | image_tag: class: 'mega-menu__collection-card-img', loading: 'lazy' }}
                                      {%- else -%}
                                        {{ 'collection-apparel-1' | placeholder_svg_tag: 'mega-menu__collection-card-img placeholder-svg' }}
                                      {%- endif -%}
                                    </div>
                                    <span class="mega-menu__collection-card-label">{{ childlink.title | escape }}</span>
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                            <button class="mega-menu__swiper-btn mega-menu__swiper-btn--prev swiper-button-prev" aria-label="Previous"></button>
                            <button class="mega-menu__swiper-btn mega-menu__swiper-btn--next swiper-button-next" aria-label="Next"></button>
                          </div>
                        </div>
                        <script>
                          (function(){
                            function initCLSwiper(){
                              if(typeof Swiper==='undefined'){setTimeout(initCLSwiper,80);return;}
                              var el=document.getElementById('{{ cl_slider_id }}');
                              if(!el||el._swInit)return;
                              el._swInit=true;
                              new Swiper(el,{
                                slidesPerView:{{ item_mega_columns }},
                                spaceBetween:16,
                                navigation:{prevEl:el.querySelector('.swiper-button-prev'),nextEl:el.querySelector('.swiper-button-next')},
                                breakpoints:{0:{slidesPerView:2},750:{slidesPerView:3},990:{slidesPerView:{{ item_mega_columns }}}}
                              });
                            }
                            var det=document.getElementById('Details-HeaderMenu-{{ forloop.index }}');
                            if(det) det.addEventListener('toggle',function(){if(det.open)initCLSwiper();},{once:true});
                          })();
                        </script>

                      {%- else -%}
                        {%- comment -%} Fits in grid — static layout {%- endcomment -%}
                        <ul
                          class="mega-menu__list mega-menu__list--collection-list"
                          role="list"
                          style="--mega-columns: {{ item_mega_columns }};"
                        >
                          {%- for childlink in link.links -%}
                            {%- liquid
                              assign cl_img = nil
                              if childlink.object and childlink.object.featured_image
                                assign cl_img = childlink.object.featured_image
                              endif
                            -%}
                            <li class="mega-menu__collection-card">
                              <a
                                href="{{ childlink.url }}"
                                class="mega-menu__collection-card-link link{% if childlink.current %} mega-menu__link--active{% endif %}"
                                {% if childlink.current %}aria-current="page"{% endif %}
                              >
                                <div class="mega-menu__collection-card-media">
                                  {%- if cl_img != blank -%}
                                    {{ cl_img | image_url: width: 300 | image_tag: class: 'mega-menu__collection-card-img', loading: 'lazy' }}
                                  {%- else -%}
                                    {{ 'collection-apparel-1' | placeholder_svg_tag: 'mega-menu__collection-card-img placeholder-svg' }}
                                  {%- endif -%}
                                </div>
                                <span class="mega-menu__collection-card-label">{{ childlink.title | escape }}</span>
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                    {%- comment -%}──────── LAYOUT: featured (image + links) ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'featured' -%}
                      <div class="mega-menu__featured">
                        {%- if item_mega_image != blank -%}
                          <div class="mega-menu__featured-image">
                            <a href="{{ item_mega_link | default: link.url }}">
                              {{ item_mega_image | image_url: width: 600 | image_tag: class: 'mega-menu__featured-img', loading: 'lazy' }}
                            </a>
                            {%- if item_mega_heading != blank -%}
                              <p class="mega-menu__featured-heading">{{ item_mega_heading }}</p>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                        <ul
                          class="mega-menu__list mega-menu__list--featured{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                          role="list"
                          style="--mega-columns: {{ item_mega_columns }};"
                        >
                          {%- for childlink in link.links -%}
                            {%- render 'mega-menu-link-item',
                              childlink: childlink,
                              link: link,
                              show_desc: item_show_desc
                            -%}
                          {%- endfor -%}
                        </ul>
                      </div>

                    {%- comment -%}──────── LAYOUT: fullwidth ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'fullwidth' -%}
                      {%- if item_mega_image != blank -%}
                        <div class="mega-menu__fullwidth-banner">
                          <a href="{{ item_mega_link | default: link.url }}">
                            {{ item_mega_image | image_url: width: 1600 | image_tag: class: 'mega-menu__fullwidth-img', loading: 'lazy' }}
                          </a>
                          {%- if item_mega_heading != blank -%}
                            <div class="mega-menu__fullwidth-heading">{{ item_mega_heading }}</div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      <ul
                        class="mega-menu__list mega-menu__list--fullwidth{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                        role="list"
                        style="--mega-columns: {{ item_mega_columns }};"
                      >
                        {%- for childlink in link.links -%}
                          <li>
                            <a
                              href="{{ childlink.url }}"
                              class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                              {% if childlink.current %}aria-current="page"{% endif %}
                            >{{ childlink.title | escape }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>

                    {%- comment -%}──────── LAYOUT: grid (images) ────────{%- endcomment -%}
                    {%- elsif item_mega_layout == 'grid' -%}
                      <ul
                        class="mega-menu__list mega-menu__list--grid"
                        role="list"
                        style="--mega-columns: {{ item_mega_columns }};"
                      >
                        {%- for childlink in link.links -%}
                          <li>
                            {%- if childlink.object and childlink.object.featured_image -%}
                              <a href="{{ childlink.url }}" class="mega-menu__grid-item link">
                                {{ childlink.object.featured_image | image_url: width: 400 | image_tag: class: 'mega-menu__grid-img', loading: 'lazy' }}
                              </a>
                            {%- endif -%}
                            <a
                              id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                              href="{{ childlink.url }}"
                              class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                              {% if childlink.current %}aria-current="page"{% endif %}
                            >{{ childlink.title | escape }}</a>
                            {%- if childlink.links != blank -%}
                              <ul class="list-unstyled" role="list">
                                {%- for grandchildlink in childlink.links -%}
                                  <li>
                                    <a
                                      href="{{ grandchildlink.url }}"
                                      class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                      {% if grandchildlink.current %}aria-current="page"{% endif %}
                                    >{{ grandchildlink.title | escape }}</a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          </li>
                        {%- endfor -%}
                      </ul>

                    {%- endif -%}{%- comment -%} end layout cases {%- endcomment -%}

                  </div>{%- comment -%} /.mega-menu__inner {%- endcomment -%}
                </div>{%- comment -%} /.mega-menu__content {%- endcomment -%}
              </details>
            </header-menu>

          {%- endif -%}{%- comment -%} end mega vs dropdown {%- endcomment -%}

        {%- else -%}
          {%- comment -%}═══ Plain link (no children or type=none) ═══{%- endcomment -%}
          <a
            id="HeaderMenu-{{ link.handle }}"
            href="{{ link.url }}"
            class="header__menu-item list-menu__item link link--text focus-inset"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {%- if item_icon_show and item_icon_image != blank -%}
              <span class="header__menu-icon">
                {{- item_icon_image | image_url: width: 24 | image_tag: width: 24, height: 24, loading: 'lazy' -}}
              </span>
            {%- endif -%}
            <span {%- if link.current %} class="header__active-menu-item"{% endif %}>
              {{- link.title | escape -}}
            </span>
          </a>
        {%- endif -%}

      </li>
    {%- endfor -%}
  </ul>
</nav>
