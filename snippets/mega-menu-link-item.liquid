{% comment %}
  Renders a single mega menu child link with optional grandchildren and description.

  Accepts:
  - childlink: {Object} the child link object
  - link:      {Object} the parent link (for id namespacing)
  - show_desc: {Boolean} show link description if available
{% endcomment %}

<li>
  <a
    id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
    href="{{ childlink.url }}"
    class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
    {% if childlink.current %}aria-current="page"{% endif %}
  >
    {{ childlink.title | escape }}
  </a>
  {%- if show_desc and childlink.object.description != blank -%}
    <p class="mega-menu__link-desc">{{ childlink.object.description | strip_html | truncate: 80 }}</p>
  {%- endif -%}
  {%- if childlink.links != blank -%}
    <ul class="list-unstyled mega-menu__grandchild-list" role="list">
      {%- for grandchildlink in childlink.links -%}
        <li>
          <a
            id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
            href="{{ grandchildlink.url }}"
            class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
            {% if grandchildlink.current %}aria-current="page"{% endif %}
          >
            {{ grandchildlink.title | escape }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</li>
